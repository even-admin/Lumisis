---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { SERVICES, prefixBase } from '@/lib/constants';
import { heroSolutions, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.en;
---

<PageLayout title="Solutions — LUMISIS" description="Strategic consulting, executive coaching, culture evolution and more.">
  {/* Hero */}
  <section class="hero-inner">
    <Image
      src={heroSolutions}
      alt=""
      width={1920}
      quality={82}
      loading="eager"
      fetchpriority="high"
      class="hero-inner__bg"
    />
    <div class="hero-inner__overlay"></div>
    <Container>
      <div class="hero-inner__content">
        <span class="hero-inner__eyebrow" data-reveal>Solutions</span>
        <h1 class="hero-inner__title" data-reveal data-reveal-delay="120">Unleashing Potential</h1>
        <p class="hero-inner__lede" data-reveal data-reveal-delay="280">
          We turn uncertainty into a definitive turning point for your future.
        </p>
      </div>
    </Container>
  </section>

  {/* Service Grid — framed bento mosaic */}
  <Section>
    <Container>
      <h2 class="services__title" data-reveal>Our services</h2>
      <div class="solutions-grid">
        <div class="services__mosaic">
          {services.map((service, i) => {
            const img = SERVICE_IMAGES[service.slug];
            return (
              <a
                href={prefixBase(`/en/solutions/${service.slug}`)}
                class="service-tile"
                data-reveal
                data-reveal-delay={`${120 + i * 80}`}
              >
                {img && (
                  <Image
                    src={img}
                    alt={service.title}
                    width={800}
                    quality={80}
                    class="service-tile__img"
                  />
                )}
                <div class="service-tile__overlay"></div>
                <div class="service-tile__content">
                  <h3 class="service-tile__title">{service.title}</h3>
                  <span class="service-tile__cta">
                    <span class="service-tile__cta-label">Explore</span>
                    <span class="service-tile__cta-arrow">&rarr;</span>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </Container>
  </Section>
</PageLayout>
