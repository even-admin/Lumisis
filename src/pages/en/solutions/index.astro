---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { SERVICES } from '@/lib/constants';

const services = SERVICES.en;
---

<PageLayout title="Solutions — LUMISIS" description="Strategic consulting, executive coaching, culture evolution and more.">
  <section class="flex min-h-[50vh] items-end bg-gray-50 pb-16">
    <Container>
      <h1 class="text-4xl md:text-5xl">Unleashing Potential</h1>
      <p class="mt-4 font-display text-xl italic text-gray-600">We turn uncertainty into a definitive turning point for your future.</p>
    </Container>
  </section>

  <Section>
    <Container>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a href={`/en/solutions/${service.slug}`} class="group relative block aspect-[4/3] overflow-hidden bg-gray-200 no-underline">
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" />
            <div class="absolute bottom-0 left-0 p-6">
              <h2 class="text-xl text-white">{service.title}</h2>
              <span class="mt-2 inline-block text-xs font-semibold tracking-widest uppercase text-white/70 transition-colors group-hover:text-white">Explore →</span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </Section>
</PageLayout>
