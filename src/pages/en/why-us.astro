---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { prefixBase } from '@/lib/constants';
import { heroWhyUs, TEAM_MEMBERS } from '@/lib/images';

const fronts = [
  'Strategic — aligned to the business strategy',
  'Functional — practical, real-world application',
  'Institutional — professionalization and capabilities in an ESG environment',
  'Profitable — value, ROI, ROE and growth',
  'People — mindset, competencies and a systemic approach',
];

const process = [
  { label: 'Inquire', copy: 'We step into your organization with an appreciative inquiry to understand it in depth.' },
  { label: 'Co-create', copy: 'We co-create a tailored solution for the strategy-aligned challenges, and build a prototype.' },
  { label: 'Activate', copy: 'We deliver the designed promise with precision and power.' },
  { label: 'Sustain', copy: 'We follow through and strengthen the results over time.' },
];

const countries = ['Mexico', 'Germany', 'France', 'Switzerland', 'England', 'Kenya', 'South Africa', 'Canada', 'United States', 'Colombia', 'Argentina', 'Brazil', 'Japan'];
const clientTypes = ['Multinationals', 'SMEs', 'Public companies', 'Family businesses'];

const values = [
  { title: "This doesn't have to be suffered", copy: 'We believe in well-being and enjoyment — results are possible while keeping the person and the team in balance.' },
  { title: 'Centered on people and their aspirations', copy: "We're convinced that people are People — and that individual goals can align with the organization's objectives." },
  { title: 'Embrace the emergent', copy: "We know we live in a VUCCA world and we're ready for whatever surfaces — from a disruptive and constructive stance." },
  { title: 'Rigor and craft', copy: 'We work with objectivity and data, with deep experience at every level. We tend every detail with professionalism, lead by example, and hold the path with composure and resilience.' },
];
---

<PageLayout title="Why Us? — LUMISIS" description="Intention, purpose and unprecedented results. Discover why companies choose LUMISIS.">
  {/* Hero */}
  <section class="hero-inner">
    <Image
      src={heroWhyUs}
      alt=""
      width={1920}
      quality={82}
      class="hero-inner__bg"
    />
    <div class="hero-inner__overlay"></div>
    <Container>
      <div class="hero-inner__content">
        <span class="hero-inner__eyebrow" data-reveal>Why Us?</span>
        <h1 class="hero-inner__title" data-reveal data-reveal-delay="120">
          Resonant Strategic<br />Breakthroughs
        </h1>
        <p class="hero-inner__lede" data-reveal data-reveal-delay="280">
          Strategy, consulting and coaching &mdash; built to leave an echo.
        </p>
      </div>
    </Container>
  </section>

  {/* Our Philosophy — RSB deep-dive + 7 values (white-principal) */}
  <Section class="whyus-philosophy">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Our Philosophy</p>
      <h2 class="whyus-philosophy__title" data-reveal data-reveal-delay="80">
        Resonant Strategic Breakthroughs
      </h2>

      <ol class="whyus-manifesto" role="list">
        <li class="whyus-manifesto__movement" data-reveal data-reveal-delay="160">
          <span class="whyus-manifesto__num">01</span>
          <span class="whyus-manifesto__eyebrow">Echo</span>
          <p>Everything we do is <em class="whyus-philosophy__accent">resonant</em> — it echoes and reverberates powerfully through organizations, people and the planet.</p>
        </li>
        <li class="whyus-manifesto__movement" data-reveal data-reveal-delay="240">
          <span class="whyus-manifesto__num">02</span>
          <span class="whyus-manifesto__eyebrow">Intention</span>
          <p>We work with intention, forethought, planning and a <em class="whyus-philosophy__accent">strategic approach</em>. We don't engage with aimless work — the "why" is crucial in every one of our professional interventions.</p>
        </li>
        <li class="whyus-manifesto__movement" data-reveal data-reveal-delay="320">
          <span class="whyus-manifesto__num">03</span>
          <span class="whyus-manifesto__eyebrow">Breakthrough</span>
          <p>The results we generate have no precedent — we aim for a <em class="whyus-philosophy__accent">breakthrough</em>, not marginal growth or incremental movement. The impact becomes a turning point participants reference as a before-and-after LUMISIS&reg; entered their lives.</p>
        </li>
      </ol>

      <h3 class="whyus-values__heading" data-reveal data-reveal-delay="400">Our Values</h3>
      <ul class="whyus-values" role="list">
        {values.map((v, i) => (
          <li data-reveal data-reveal-delay={`${440 + i * 70}`}>
            <details class="whyus-value">
              <summary class="whyus-value__head">
                <span class="whyus-value__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="whyus-value__title">{v.title}</span>
                <span class="whyus-value__icon" aria-hidden="true"></span>
              </summary>
              <div class="whyus-value__body">
                <p class="whyus-value__copy">{v.copy}</p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  {/* Leadership Team — mosaic on brand-black */}
  <Section bg="dark" class="whyus-team">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Experts</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Leadership Team</h2>
      <p class="whyus-team__intro max-w-xl" data-reveal data-reveal-delay="160">
        High-caliber strategists, consultants and coaches — part of a wider team of international experts.
      </p>

      <div class="whyus-team__mosaic">
        {TEAM_MEMBERS.en.map((member, i) => (
          <div
            class="whyus-team__tile"
            data-reveal
            data-reveal-delay={`${200 + i * 80}`}
          >
            <Image
              src={member.image}
              alt=""
              width={600}
              quality={85}
              class="whyus-team__photo"
            />
            <div class="whyus-team__overlay"></div>
            <div class="whyus-team__content">
              <p class="whyus-team__name">{member.name}</p>
              <p class="whyus-team__title">{member.title}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="whyus-team__note" data-reveal data-reveal-delay="640">
        Meet the full team at LUMISIS.
      </p>
    </Container>
  </Section>

  {/* How we work — the 4 Ds */}
  <Section>
    <Container>
      <p class="eyebrow mb-4" data-reveal>Our process</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">How we work</h2>
      <ol class="whyus-process" role="list">
        {process.map((step, i) => (
          <li
            class="whyus-process__step"
            data-reveal
            data-reveal-delay={`${120 + i * 100}`}
          >
            <span class="whyus-process__num">{String(i + 1).padStart(2, '0')}</span>
            <p class="whyus-process__label">{step.label}</p>
            <p class="whyus-process__copy">{step.copy}</p>
          </li>
        ))}
      </ol>
    </Container>
  </Section>

  {/* Why Companies Choose Lumisis — the five fronts + integrated count-up */}
  <Section class="whyus-rule">
    <Container>
      <div class="grid gap-16 md:grid-cols-2">
        <div class="whyus-enfoque__intro" data-reveal>
          <p class="eyebrow mb-4">Why Us?</p>
          <h2 class="text-3xl md:text-4xl">
            Why Companies Choose Lumisis&reg;
          </h2>
          <p class="mt-6 text-gray-600">
            We approach every challenge with intention, forethought, planning and a strategic mindset — aligned to the business strategy across its five strategic horizons.
          </p>
        </div>
        <div class="whyus-enfoque__list">
          <p class="eyebrow mb-6" data-reveal data-reveal-delay="100">We work on five fronts:</p>
          <ol class="why-us__list" role="list">
            {fronts.map((item, i) => (
              <li
                class="why-us__item"
                data-reveal
                data-reveal-delay={`${200 + i * 60}`}
              >
                <span class="why-us__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="why-us__label">{item}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <hr class="whyus-stats__divider" data-reveal />
      <div class="whyus-stats__grid">
        <div class="whyus-stat" data-reveal data-reveal-delay="120">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={5} prefix="+" suffix="k" />
          </span>
          <span class="whyus-stat__label">Workshops</span>
        </div>
        <div class="whyus-stat" data-reveal data-reveal-delay="200">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={50} prefix="+" suffix="k" />
          </span>
          <span class="whyus-stat__label">Talent Release Hours</span>
        </div>
        <div class="whyus-stat" data-reveal data-reveal-delay="280">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={400} prefix="+" />
          </span>
          <span class="whyus-stat__label">Conferences</span>
        </div>
      </div>
    </Container>
  </Section>

  {/* Footprint — Global Reach (brand-black, editorial closer) */}
  <Section bg="dark" class="whyus-footprint">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Our Footprint</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Global Reach</h2>
      <p class="whyus-footprint__intro" data-reveal data-reveal-delay="140">
        We have served clients internationally, across five continents.
      </p>

      <div
        class="whyus-footprint__stat"
        role="group"
        aria-label="More than 30 countries served"
        data-reveal
        data-reveal-delay="200"
      >
        <span class="whyus-footprint__stat-num" aria-hidden="true">+30</span>
        <span class="whyus-footprint__stat-rule" aria-hidden="true"></span>
        <span class="whyus-footprint__stat-label" aria-hidden="true">Countries served</span>
      </div>

      <ul class="whyus-footprint__countries" role="list">
        {countries.map((name, i) => (
          <li
            class="whyus-footprint__country"
            data-reveal
            data-reveal-delay={`${220 + i * 22}`}
          >
            <span class="whyus-footprint__country-mark" aria-hidden="true"></span>
            <span class="whyus-footprint__country-name">{name}</span>
          </li>
        ))}
      </ul>

      <p class="whyus-footprint__note" data-reveal data-reveal-delay="500">
        To name a few.
      </p>

      <ul class="whyus-footprint__detail" role="list" data-reveal data-reveal-delay="520">
        {clientTypes.map((type) => <li>{type}</li>)}
      </ul>

      <div class="whyus-footprint__cta" data-reveal data-reveal-delay="580">
        <a href={prefixBase('/en/contact')} class="cta-pill cta-pill--solid" aria-label="Start a conversation">
          <span class="letters">
            {'START A CONVERSATION'.split('').map((char, i) => (
              char === ' '
                ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
            ))}
          </span>
          <span class="cta-pill__arrow">&rarr;</span>
        </a>
        <a href={prefixBase('/en/solutions')} class="cta-pill cta-pill--outline" aria-label="View solutions">
          <span class="letters">
            {'VIEW SOLUTIONS'.split('').map((char, i) => (
              char === ' '
                ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
            ))}
          </span>
        </a>
      </div>
    </Container>
  </Section>
</PageLayout>
