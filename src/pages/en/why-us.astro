---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { Globe } from '@/components/islands/Globe';
import { GLOBE_PINS } from '@/lib/constants';
import { heroWhyUs, PARTNER_LOGOS, TEAM_MEMBERS, footprintMap } from '@/lib/images';
---

<PageLayout title="Why Us? — LUMISIS" description="Intention, purpose and unprecedented results. Discover why companies choose LUMISIS.">
  {/* Hero */}
  <section class="relative flex min-h-[60vh] items-end overflow-hidden pb-16 text-white">
    <Image
      src={heroWhyUs}
      alt=""
      width={1920}
      quality={80}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/50" />
    <Container>
      <h1 class="relative text-4xl md:text-5xl text-white">Resonant Strategic<br />Breakthroughs</h1>
    </Container>
  </section>

  {/* Three Principles */}
  <Section>
    <Container>
      <div class="grid gap-16 md:grid-cols-3">
        <div>
          <p class="eyebrow mb-4">01</p>
          <h3>The Power of Intention</h3>
          <p class="mt-4 text-gray-600">We ensure that every intervention is not just active, but purposeful. Creating a powerful, positive echo that extends beyond the boardroom.</p>
        </div>
        <div>
          <p class="eyebrow mb-4">02</p>
          <h3>A Definitive Turning Point</h3>
          <p class="mt-4 text-gray-600">Our goal is to generate unprecedented results that serve as a true turning point — a clear "before and after" in the life of your organization.</p>
        </div>
        <div>
          <p class="eyebrow mb-4">03</p>
          <h3>The Echo</h3>
          <p class="mt-4 text-gray-600">Everything we do is designed to be resonant. We ensure that our work vibrates with purpose long after the engagement ends.</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* Partners */}
  <div class="border-y border-gray-200 py-12">
    <Container>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        {PARTNER_LOGOS.map((logo, i) => (
          <Image
            src={logo}
            alt={`Partner ${i + 1}`}
            height={32}
            quality={85}
            class="h-8 w-auto opacity-50 grayscale transition-opacity hover:opacity-80"
          />
        ))}
      </div>
    </Container>
  </div>

  {/* Leadership Team */}
  <Section>
    <Container>
      <p class="eyebrow mb-4">Experts</p>
      <h2 class="mb-4 text-3xl md:text-4xl">Leadership Team</h2>
      <p class="mb-12 max-w-xl text-gray-600">Our approach is defined by deep thoughtfulness, rigorous planning, and a strategic mindset.</p>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
        {TEAM_MEMBERS.map((member) => (
          <div class="text-center">
            <div class="mx-auto aspect-square w-full max-w-[200px] overflow-hidden">
              <Image
                src={member.image}
                alt={member.name}
                width={400}
                quality={85}
                class="h-full w-full object-cover"
              />
            </div>
            <p class="mt-4 font-medium">{member.name}</p>
            <p class="text-sm text-gray-500">{member.title}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* Stats */}
  <Section bg="dark">
    <Container>
      <p class="eyebrow mb-8 text-gray-400">We Create an Echo</p>
      <div class="grid gap-8 text-center md:grid-cols-3">
        {[
          { value: '+0k', label: 'Workshops' },
          { value: '+0k', label: 'Talent Release Hours' },
          { value: '+0', label: 'Conferences' },
        ].map((stat) => (
          <div>
            <p class="font-display text-5xl text-white">{stat.value}</p>
            <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">{stat.label}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* Footprint / Globe */}
  <Section bg="dark">
    <Container narrow>
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl text-white">Our Footprint</h2>
        <p class="mx-auto mt-6 text-gray-400">At LUMISIS Group, we address challenges with a global mindset. We have developed projects in more than <strong class="text-white">47 countries</strong> spread across <strong class="text-white">7 continents.</strong></p>
        <div class="mx-auto mt-8 aspect-square max-w-[600px]">
          <Globe client:visible pins={GLOBE_PINS} />
        </div>
        <noscript>
          <Image
            src={footprintMap}
            alt="LUMISIS global footprint — 47 countries, 7 continents"
            width={1200}
            quality={85}
            class="mx-auto mt-12"
          />
        </noscript>
      </div>
    </Container>
  </Section>
</PageLayout>
