---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import { Globe } from '@/components/islands/Globe';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { SERVICES, prefixBase, GLOBE_PINS } from '@/lib/constants';
import { heroHomeAlt, CLIENT_LOGOS, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.en;

// Toggle the logo marquee on/off. Keep false until the team confirms the
// final logo list — placeholder logos risk client-conflict optics.
const SHOW_LOGO_BAND = false;
---

<PageLayout title="LUMISIS — Strategy | Consulting | Coaching" description="Strategic consulting, executive coaching and culture evolution for organizations.">
  {/* Hero — People-photo with dark overlay (LUMISIS brand-true, negative mode) */}
  <section class="hero-people">
    <Image
      src={heroHomeAlt}
      alt=""
      width={1920}
      quality={82}
      loading="eager"
      fetchpriority="high"
      class="hero-people__bg"
    />
    <div class="hero-people__overlay"></div>
    <Container>
      <div class="hero-people__content">
        <span class="hero-people__eyebrow" data-reveal>Strategy &nbsp;|&nbsp; Consulting &nbsp;|&nbsp; Coaching</span>
        <h1 class="hero-people__title" data-reveal data-reveal-delay="120">
          Thrive Through<br />Uncertainty.
        </h1>
        <p class="hero-people__lede" data-reveal data-reveal-delay="280">
          Unleashing the Potential of Organizations, Leaders, and Cultures.
        </p>
        <div class="hero-people__cta" data-reveal data-reveal-delay="440">
          <a href={prefixBase('/en/contact')} class="cta-pill cta-pill--solid" aria-label="Start a conversation">
            <span class="letters">
              {'START A CONVERSATION'.split('').map((char, i) => (
                char === ' '
                  ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                  : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
              ))}
            </span>
            <span class="cta-pill__arrow">&rarr;</span>
          </a>
          <a href={prefixBase('/en/solutions')} class="cta-pill cta-pill--outline">
            <span class="letters">
              {'VIEW SOLUTIONS'.split('').map((char, i) => (
                char === ' '
                  ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                  : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
              ))}
            </span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Intro — Who We Are */}
  <section class="home-intro">
    <Container>
      <p class="eyebrow home-intro__eyebrow" data-reveal>Who we are</p>
      <h2 class="home-intro__statement" data-reveal data-reveal-delay="120">
        A strategy, consulting and coaching firm for <span class="home-intro__mark">the moments that define the future</span> of an organization.
      </h2>
      <p class="home-intro__supporting" data-reveal data-reveal-delay="280">
        We work alongside CEOs, boards and leadership teams through their most critical transitions: <em class="home-intro__chip">accelerated growth</em>, <em class="home-intro__chip">succession</em>, <em class="home-intro__chip">institutionalization</em>, <em class="home-intro__chip">cultural evolution</em>. Our strategists, consultants and coaches are international experts, used to challenging the status quo, unleashing potential and accelerating the learning curve.
      </p>

      <div class="home-intro__pillars">
        {[
          { label: 'Strategy', copy: 'Strategic services: planning, execution and future design.' },
          { label: 'Consulting', copy: 'Consulting and best practices to institutionalize the business.' },
          { label: 'Coaching', copy: 'Coaching and talent release for leaders and teams.' },
        ].map((p, i) => (
          <div
            class="home-intro__pillar"
            data-reveal
            data-reveal-delay={`${440 + i * 100}`}
          >
            <span class="home-intro__pillar-num">{String(i + 1).padStart(2, '0')}</span>
            <p class="home-intro__pillar-label">{p.label}</p>
            <p class="home-intro__pillar-copy">{p.copy}</p>
          </div>
        ))}
      </div>

      <a href={prefixBase('/en/why-us')} class="home-intro__cta" data-reveal data-reveal-delay="740">
        <span class="home-intro__cta-label">Discover our approach</span>
        <span class="home-intro__cta-arrow">&rarr;</span>
      </a>
    </Container>
  </section>

  {SHOW_LOGO_BAND && (
  <section class="logo-marquee" aria-label="Trusted by">
    <Container>
      <p class="eyebrow logo-marquee__eyebrow">Trusted by</p>
    </Container>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--left">
        <div class="logo-marquee__copy">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
        <div class="logo-marquee__copy" aria-hidden="true">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
      </div>
    </div>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--right">
        <div class="logo-marquee__copy">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
        <div class="logo-marquee__copy" aria-hidden="true">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
      </div>
    </div>
  </section>
  )}

  {/* Global presence — merged Offices + Stats editorial composition */}
  <section class="presencia" id="presencia">
    <Container>
      <div class="presencia__grid">
        <div class="presencia__col presencia__col--left">
          <p class="presencia__eyebrow" data-reveal>Track record</p>
          <h2 class="presencia__title" data-reveal data-reveal-delay="120">Global presence.</h2>
          <p class="presencia__lede" data-reveal data-reveal-delay="200">
            More than 20 years guiding critical transitions in organizations across 30+ countries.
          </p>
          <div class="presencia__globe">
            <Globe client:visible pins={GLOBE_PINS} showLabels={false} pinSize={0.008} />
          </div>
        </div>

        <div class="presencia__content">
          <ul class="presencia__stats">
            <li class="presencia-stat" data-reveal data-reveal-delay="240">
              <span class="presencia-stat__num">
                <AnimatedNumber client:visible end={800} prefix="+" />
              </span>
              <span class="presencia-stat__label">Companies</span>
            </li>
            <li class="presencia-stat" data-reveal data-reveal-delay="320">
              <span class="presencia-stat__num">
                <AnimatedNumber client:visible end={100} prefix="+" suffix="k" />
              </span>
              <span class="presencia-stat__label">Impacted Executives</span>
            </li>
            <li class="presencia-stat" data-reveal data-reveal-delay="400">
              <span class="presencia-stat__num">
                <AnimatedNumber client:visible end={30} prefix="+" />
              </span>
              <span class="presencia-stat__label">Countries</span>
            </li>
          </ul>

          <hr class="presencia__divider" data-reveal data-reveal-delay="520" />

          <div class="presencia__offices">
            <p class="presencia__offices-label" data-reveal data-reveal-delay="600">Offices</p>
            <ul class="presencia__cities">
              <li data-reveal data-reveal-delay="680"><span class="city__name">Mérida</span><span class="city__region">Mexico · HQ</span></li>
              <li data-reveal data-reveal-delay="740"><span class="city__name">Mexico City</span><span class="city__region">Mexico</span></li>
              <li data-reveal data-reveal-delay="800"><span class="city__name">Chihuahua</span><span class="city__region">Mexico</span></li>
              <li data-reveal data-reveal-delay="860"><span class="city__name">San Diego</span><span class="city__region">United States</span></li>
              <li data-reveal data-reveal-delay="920"><span class="city__name">Berlin</span><span class="city__region">Germany</span></li>
            </ul>
          </div>

          <a href={prefixBase('/en/contact')} class="presencia__cta" data-reveal data-reveal-delay="1040">
            <span class="presencia__cta-label">Talk to an expert</span>
            <span class="presencia__cta-arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Services — Asymmetric Bento Mosaic */}
  <section class="services">
    <Container>
      <div class="services__header">
        <p class="services__eyebrow" data-reveal>Solutions</p>
        <h2 class="services__title" data-reveal data-reveal-delay="120">Our Services</h2>
      </div>

      <div class="services__mosaic">
        {services.map((service, i) => {
          const img = SERVICE_IMAGES[service.slug];
          return (
            <a
              href={prefixBase(`/en/solutions/${service.slug}`)}
              class="service-tile"
              data-reveal
              data-reveal-delay={`${240 + i * 80}`}
            >
              {img && (
                <Image
                  src={img}
                  alt={service.title}
                  width={800}
                  quality={80}
                  class="service-tile__img"
                />
              )}
              <div class="service-tile__overlay"></div>
              <div class="service-tile__content">
                <h3 class="service-tile__title">{service.title}</h3>
                <span class="service-tile__cta">
                  <span class="service-tile__cta-label">Explore</span>
                  <span class="service-tile__cta-arrow">&rarr;</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </section>

</PageLayout>

<script>
  // Single, persistent scroll listener — re-queries marks each tick so View
  // Transitions just work without leaking listeners across navigations.
  (function initMarkProgress() {
    function update() {
      const marks = document.querySelectorAll<HTMLElement>('.home-intro__mark');
      if (!marks.length) return;
      const vh = window.innerHeight;
      const startY = vh * 0.90; // phrase top here → progress 0
      const endY = vh * 0.30;   // phrase top here → progress 1
      const span = startY - endY;
      for (const mark of marks) {
        const rect = mark.getBoundingClientRect();
        const raw = (startY - rect.top) / span;
        const progress = raw < 0 ? 0 : raw > 1 ? 1 : raw;
        mark.style.setProperty('--mark-progress', progress.toString());
      }
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    document.addEventListener('astro:page-load', update);
    update();
  })();
</script>
