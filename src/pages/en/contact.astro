---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
---

<PageLayout title="Contact — LUMISIS" description="Collaborate with our experts to create impactful experiences together.">
  <Section>
    <Container narrow>
      <div class="grid gap-16 md:grid-cols-2">
        <div>
          <p class="eyebrow mb-4">Contact Us</p>
          <h1 class="text-3xl md:text-4xl">Start Your Next Strategic Breakthrough</h1>
          <p class="mt-6 text-gray-600">Not sure where to start? Request a Needs Detection session (DNE) — a no-cost conversation where we listen to your situation and the challenges you face before proposing anything.</p>
        </div>
        <form class="space-y-6" data-contact-form>
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Your Name *</label>
            <input type="text" id="name" name="name" required class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-2">Your Email *</label>
            <input type="email" id="email" name="email" required class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-2">Message</label>
            <textarea id="message" name="message" rows="4" class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black resize-none"></textarea>
          </div>
          <div class="contact-submit">
            <Button variant="primary">Send Message</Button>
            <p class="contact-hashtag">#ItsTime</p>
          </div>
        </form>
      </div>
    </Container>
  </Section>
</PageLayout>
