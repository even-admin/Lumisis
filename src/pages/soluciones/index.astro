---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { SERVICES, prefixBase } from '@/lib/constants';
import { heroSolutions, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.es;
---

<PageLayout title="Soluciones — LUMISIS" description="Consultoría estratégica, coaching ejecutivo, evolución cultural y más. Descubre nuestras soluciones.">
  {/* Hero */}
  <section class="relative flex min-h-[50vh] items-end overflow-hidden pb-16 text-white">
    <Image
      src={heroSolutions}
      alt=""
      width={1920}
      quality={80}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/50" />
    <Container>
      <h1 class="relative text-4xl md:text-5xl text-white">Liberamos el potencial</h1>
      <p class="relative mt-4 font-display text-xl text-white/80 font-light">
        Convertimos la incertidumbre en un parteaguas definitivo para tu futuro.
      </p>
    </Container>
  </section>

  {/* Service Grid */}
  <Section>
    <Container>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => {
          const img = SERVICE_IMAGES[service.slug];
          return (
            <a
              href={prefixBase(`/soluciones/${service.slug}`)}
              class="group relative block aspect-[4/3] overflow-hidden bg-gray-200 no-underline"
            >
              {img && (
                <Image
                  src={img}
                  alt={service.title}
                  width={800}
                  quality={80}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" />
              <div class="absolute bottom-0 left-0 p-6">
                <h2 class="text-xl text-white">{service.title}</h2>
                <span class="mt-2 inline-block text-xs font-semibold tracking-widest uppercase text-white/70 transition-colors group-hover:text-white">
                  Explorar →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </Section>
</PageLayout>
