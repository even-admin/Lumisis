---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
---

<PageLayout title="Contacto — LUMISIS" description="Colabora con nuestros expertos para crear experiencias de impacto.">
  <Section>
    <Container narrow>
      <div class="grid gap-16 md:grid-cols-2">
        <div>
          <p class="eyebrow mb-4">Contáctanos</p>
          <h1 class="text-3xl md:text-4xl">
            Comienza tu próximo parteaguas estratégico
          </h1>
          <p class="mt-6 text-gray-600">
            ¿No sabes por dónde empezar? Solicita una Detección de Necesidades (DNE): una sesión sin costo donde escuchamos tu situación y los retos que enfrentas antes de proponer nada.
          </p>
        </div>

        <form class="space-y-6" data-contact-form>
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Tu nombre *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-2">Tu correo *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-2">Mensaje</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black resize-none"
            ></textarea>
          </div>
          <div class="contact-submit">
            <Button variant="primary">Enviar mensaje</Button>
            <p class="contact-hashtag">#YaEsHora</p>
          </div>
        </form>
      </div>
    </Container>
  </Section>
</PageLayout>
