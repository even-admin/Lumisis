---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import ContactFormScript from '@/components/ContactFormScript.astro';
---

<PageLayout title="Contacto — LUMISIS" description="Colabora con nuestros expertos para crear experiencias de impacto.">
  <Section>
    <Container narrow>
      <div class="grid gap-16 md:grid-cols-2">
        <div>
          <p class="eyebrow mb-4">Contáctanos</p>
          <h1 class="text-3xl md:text-4xl">
            Comienza tu próximo parteaguas estratégico
          </h1>
          <p class="mt-6 text-gray-600">
            ¿No sabes por dónde empezar? Solicita una Detección de Necesidades (DNE): una sesión sin costo donde escuchamos tu situación y los retos que enfrentas antes de proponer nada.
          </p>

          <a
            href="https://wa.me/5219996490203"
            class="contact-whatsapp"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Escríbenos por WhatsApp"
          >
            <svg class="contact-whatsapp__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01zM12.05 20.15h-.01a8.22 8.22 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.24 8.24 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c.01 4.54-3.69 8.23-8.23 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42-.14-.01-.31-.01-.48-.01-.16 0-.43.06-.66.31-.23.25-.87.85-.87 2.07 0 1.22.89 2.4 1.02 2.56.12.16 1.76 2.69 4.27 3.78.6.26 1.06.41 1.42.53.6.19 1.14.16 1.57.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.06-.1-.23-.16-.48-.28z" fill="currentColor"/>
            </svg>
            <span class="contact-whatsapp__label">Escríbenos por WhatsApp</span>
          </a>
        </div>

        <form
          class="space-y-6"
          data-contact-form
          action="https://formspree.io/f/mbdwvaoo"
          method="POST"
          data-sending-label="Enviando…"
        >
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Tu nombre *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              inputmode="text"
              autocomplete="name"
              autocapitalize="words"
              class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-2">Tu correo *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              inputmode="email"
              autocomplete="email"
              autocapitalize="off"
              spellcheck="false"
              class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-2">Mensaje</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full border-b border-gray-300 bg-transparent py-3 text-base outline-none transition-colors focus:border-brand-black resize-none"
            ></textarea>
          </div>
          <div class="contact-submit">
            <Button variant="primary">Enviar mensaje</Button>
            <p class="contact-hashtag">#YaEsHora</p>
            <p class="contact-form__status" data-form-success hidden>
              Mensaje enviado. Te responderemos pronto.
            </p>
            <p class="contact-form__status contact-form__status--error" data-form-error hidden>
              No se pudo enviar. Intenta de nuevo o escríbenos directo a operaciones@lumisisgroup.com.
            </p>
          </div>

          <input type="hidden" name="_subject" value="Nuevo mensaje de contacto — LUMISIS" />
          <input
            type="text"
            name="_gotcha"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="display:none"
          />
        </form>
      </div>
    </Container>
  </Section>
  <ContactFormScript />
</PageLayout>
