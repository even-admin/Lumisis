---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { heroWhyUs, PARTNER_LOGOS, TEAM_MEMBERS, footprintMap } from '@/lib/images';
---

<PageLayout title="¿Por Qué Nosotros? — LUMISIS" description="Intención, propósito y resultados sin precedentes. Descubre por qué las empresas eligen LUMISIS.">
  {/* Hero */}
  <section class="relative flex min-h-[60vh] items-end overflow-hidden pb-16 text-white">
    <Image
      src={heroWhyUs}
      alt=""
      width={1920}
      quality={80}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/50" />
    <Container>
      <h1 class="relative text-4xl md:text-5xl text-white">
        Resonant Strategic<br />Breakthroughs
      </h1>
    </Container>
  </section>

  {/* Three Principles */}
  <Section>
    <Container>
      <div class="grid gap-16 md:grid-cols-3">
        <div data-reveal>
          <p class="eyebrow mb-4">01</p>
          <h3>The Power of Intention</h3>
          <p class="mt-4 text-gray-600">
            We ensure that every intervention is not just active, but purposeful. Creating a powerful, positive echo that extends beyond the boardroom to impact your organization, your people, and the planet.
          </p>
        </div>
        <div data-reveal data-reveal-delay="120">
          <p class="eyebrow mb-4">02</p>
          <h3>A Definitive Turning Point</h3>
          <p class="mt-4 text-gray-600">
            We aim for breakthroughs. Our goal is to generate unprecedented results that serve as a true turning point — a moment that participants profoundly recognize as a clear "before and after."
          </p>
        </div>
        <div data-reveal data-reveal-delay="240">
          <p class="eyebrow mb-4">03</p>
          <h3>The Echo</h3>
          <p class="mt-4 text-gray-600">
            We do not believe in isolated actions. Everything we do is designed to be resonant. We ensure that our work vibrates with purpose long after the engagement ends.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  {/* Why Companies Choose Lumisis — tangible advantages */}
  <Section bg="light">
    <Container>
      <div class="grid gap-16 md:grid-cols-2">
        <div data-reveal>
          <p class="eyebrow mb-4">¿Por Qué Nosotros?</p>
          <h2 class="text-3xl md:text-4xl">
            Why Companies Choose Lumisis®
          </h2>
          <p class="mt-6 text-gray-600">
            We approach things with intention, thoughtfulness, planning and a strategic mindset.
          </p>
        </div>
        <div>
          <p class="eyebrow mb-6" data-reveal data-reveal-delay="100">Our Advantages Include:</p>
          <ol class="why-us__list">
            {[
              'Clear, Actionable Strategy',
              'Proven Frameworks',
              'Hands-On Implementation',
              'Transparent Costs',
              'Design for Long-Term Growth',
            ].map((item, i) => (
              <li
                class="why-us__item"
                data-reveal
                data-reveal-delay={`${200 + i * 60}`}
              >
                <span class="why-us__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="why-us__label">{item}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </Container>
  </Section>

  {/* Partners */}
  <div class="border-y border-gray-200 py-12">
    <Container>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        {PARTNER_LOGOS.map((logo, i) => (
          <Image
            src={logo}
            alt={`Partner ${i + 1}`}
            height={32}
            quality={85}
            class="h-8 w-auto opacity-50 grayscale transition-opacity hover:opacity-80"
          />
        ))}
      </div>
    </Container>
  </div>

  {/* Leadership Team */}
  <Section>
    <Container>
      <p class="eyebrow mb-4" data-reveal>Experts</p>
      <h2 class="mb-4 text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Leadership Team</h2>
      <p class="mb-12 max-w-xl text-gray-600" data-reveal data-reveal-delay="160">
        Our approach is defined by deep thoughtfulness, rigorous planning, and a strategic mindset.
      </p>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
        {TEAM_MEMBERS.map((member) => (
          <div class="text-center">
            <div class="mx-auto aspect-square w-full max-w-[200px] overflow-hidden">
              <Image
                src={member.image}
                alt={member.name}
                width={400}
                quality={85}
                class="h-full w-full object-cover"
              />
            </div>
            <p class="mt-4 font-medium">{member.name}</p>
            <p class="text-sm text-gray-500">{member.title}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* Stats */}
  <Section bg="dark">
    <Container>
      <p class="eyebrow mb-8 text-gray-400">We Create an Echo</p>
      <div class="grid gap-8 text-center md:grid-cols-3">
        <div>
          <p class="font-display text-5xl text-white">
            <AnimatedNumber client:visible end={5} prefix="+" suffix="k" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Workshops</p>
        </div>
        <div>
          <p class="font-display text-5xl text-white">
            <AnimatedNumber client:visible end={50} prefix="+" suffix="k" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Talent Release Hours</p>
        </div>
        <div>
          <p class="font-display text-5xl text-white">
            <AnimatedNumber client:visible end={400} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Conferences</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* Footprint */}
  <Section>
    <Container>
      <div class="grid gap-12 items-center md:grid-cols-2">
        <div>
          <p class="eyebrow mb-4" data-reveal>Our Footprint</p>
          <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Global Reach</h2>
          <p class="mt-6 text-gray-600" data-reveal data-reveal-delay="160">
            At LUMISIS Group, we address challenges with a global mindset. We have developed projects in more than <strong>47 countries</strong> spread across <strong>7 continents.</strong>
          </p>
        </div>
        <div>
          <Image
            src={footprintMap}
            alt="LUMISIS global footprint — 47 countries, 7 continents"
            width={1200}
            quality={85}
          />
        </div>
      </div>
    </Container>
  </Section>
</PageLayout>

<style>
  /* =========================================================
     Why Us — staggered reveal + per-row hover
     ========================================================= */
  .why-us__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .why-us__item {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.125rem 0;
    border-bottom: 1px solid rgba(57, 57, 56, 0.08);
    transition:
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .why-us__item:last-child {
    border-bottom: 0;
  }

  .why-us__num {
    font-family: var(--font-display, 'Gotham', sans-serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: rgba(57, 57, 56, 0.25);
    min-width: 2.5rem;
    transition: color 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .why-us__label {
    position: relative;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #393938;
  }

  .why-us__label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1.5px;
    background: #0098DB;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .why-us__item:hover {
    transform: translateX(4px);
    border-bottom-color: rgba(0, 152, 219, 0.35);
  }

  .why-us__item:hover .why-us__num {
    color: #0098DB;
  }

  .why-us__item:hover .why-us__label::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .why-us__item,
    .why-us__num,
    .why-us__label::after { transition: none; }
    .why-us__item:hover { transform: none; }
  }
</style>
