---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { prefixBase } from '@/lib/constants';
import { heroWhyUs, TEAM_MEMBERS } from '@/lib/images';

const fronts = [
  'Estratégico — alineados a la estrategia del negocio',
  'Funcional — de aplicación práctica y real',
  'Institucional — profesionalización y capacidades en un ambiente ESG',
  'Rentable — valor, ROI, ROE y crecimiento',
  'Personas — mindset, competencias y enfoque sistémico',
];

const process = [
  { label: 'Indagar', copy: 'Nos adentramos en tu organización con una indagación apreciativa para entenderla a fondo.' },
  { label: 'Co-crear', copy: 'Co-creamos un traje a la medida para los retos alineados a la estrategia, y materializamos un prototipo.' },
  { label: 'Activar', copy: 'Entregamos la promesa diseñada con impecabilidad y potencia.' },
  { label: 'Sostener', copy: 'Damos seguimiento y fortalecemos los resultados en el tiempo.' },
];

const countries = ['México', 'Alemania', 'Francia', 'Suiza', 'Inglaterra', 'Kenia', 'Sudáfrica', 'Canadá', 'Estados Unidos', 'Colombia', 'Argentina', 'Brasil', 'Japón'];
const clientTypes = ['Multinacionales', 'PyMES', 'Empresas públicas', 'Empresas familiares'];

const values = [
  { title: 'Esto no tiene por qué ser sufrido', copy: 'Creemos en el bienestar y el disfrute, es posible alcanzar resultados en balance de la persona y el equipo.' },
  { title: 'Centrados en las personas y sus aspiraciones', copy: 'Estamos convencidos que las personas son Personas, y que sus metas individuales se pueden alinear con los objetivos de la organización.' },
  { title: 'Abrazamos lo emergente', copy: 'Sabemos que vivimos en un mundo VUCCA y estamos listos para atender lo que se presente, desde una actitud disruptiva y constructiva.' },
  { title: 'Rigor y oficio', copy: 'Trabajamos con objetividad y datos, con experiencia profunda a todos los niveles. Cuidamos cada detalle con profesionalismo, predicando con el ejemplo, y sostenemos el camino con templanza y resiliencia.' },
];
---

<PageLayout title="¿Por Qué Nosotros? — LUMISIS" description="Intención, propósito y resultados sin precedentes. Descubre por qué las empresas eligen LUMISIS.">
  {/* Hero */}
  <section class="hero-inner">
    <Image
      src={heroWhyUs}
      alt=""
      width={1920}
      quality={82}
      class="hero-inner__bg"
    />
    <div class="hero-inner__overlay"></div>
    <Container>
      <div class="hero-inner__content">
        <span class="hero-inner__eyebrow" data-reveal>¿Por Qué Nosotros?</span>
        <h1 class="hero-inner__title" lang="en" data-reveal data-reveal-delay="120">
          Resonant Strategic<br />Breakthroughs
        </h1>
        <p class="hero-inner__lede" data-reveal data-reveal-delay="280">
          Estrategia, consultoría y coaching pensados para dejar eco.
        </p>
      </div>
    </Container>
  </section>

  {/* Filosofía Organizacional — RSB deep-dive + 7 valores (white-principal) */}
  <Section class="whyus-philosophy">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Filosofía Organizacional</p>
      <h2 class="whyus-philosophy__title" lang="en" data-reveal data-reveal-delay="80">
        Resonant Strategic Breakthroughs
      </h2>

      <ol class="whyus-manifesto" role="list">
        <li class="whyus-manifesto__movement" data-reveal data-reveal-delay="160">
          <span class="whyus-manifesto__num">01</span>
          <span class="whyus-manifesto__eyebrow">Eco</span>
          <p>Todo lo que hacemos es <em class="whyus-philosophy__accent">resonante</em>, tiene eco y repercute de manera poderosa en las organizaciones, en las personas y en el planeta.</p>
        </li>
        <li class="whyus-manifesto__movement" data-reveal data-reveal-delay="240">
          <span class="whyus-manifesto__num">02</span>
          <span class="whyus-manifesto__eyebrow">Intención</span>
          <p>Hacemos las cosas con intención, premeditación, planeación y con un <em class="whyus-philosophy__accent">planteamiento estratégico</em>. No nos gusta trabajar en temas "sin sentido", y por ende el "para qué" es crucial en todas nuestras intervenciones profesionales.</p>
        </li>
        <li class="whyus-manifesto__movement" data-reveal data-reveal-delay="320">
          <span class="whyus-manifesto__num">03</span>
          <span class="whyus-manifesto__eyebrow">Parteaguas</span>
          <p>Los resultados que generamos no tienen precedente y apuntamos más a un <em class="whyus-philosophy__accent">breakthrough</em> que a un crecimiento o movimiento marginal de las cosas. El impacto apunta a convertirse en un parteaguas al que los participantes refieran de manera trascendental como un antes y un después de que LUMISIS&reg; llegara a sus vidas.</p>
        </li>
      </ol>

      <h3 class="whyus-values__heading" data-reveal data-reveal-delay="400">Nuestros Valores</h3>
      <ul class="whyus-values" role="list">
        {values.map((v, i) => (
          <li data-reveal data-reveal-delay={`${440 + i * 70}`}>
            <details class="whyus-value">
              <summary class="whyus-value__head">
                <span class="whyus-value__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="whyus-value__title">{v.title}</span>
                <span class="whyus-value__icon" aria-hidden="true"></span>
              </summary>
              <div class="whyus-value__body">
                <p class="whyus-value__copy">{v.copy}</p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  {/* Equipo de Liderazgo — mosaico sobre brand-black */}
  <Section bg="dark" class="whyus-team">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Expertos</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Equipo de Liderazgo</h2>
      <p class="whyus-team__intro max-w-xl" data-reveal data-reveal-delay="160">
        Estrategas, consultores y coaches de alto perfil — parte de un equipo más amplio de expertos internacionales.
      </p>

      <div class="whyus-team__mosaic">
        {TEAM_MEMBERS.es.map((member, i) => (
          <div
            class="whyus-team__tile"
            data-reveal
            data-reveal-delay={`${200 + i * 80}`}
          >
            <Image
              src={member.image}
              alt=""
              width={600}
              quality={85}
              class="whyus-team__photo"
            />
            <div class="whyus-team__overlay"></div>
            <div class="whyus-team__content">
              <p class="whyus-team__name">{member.name}</p>
              <p class="whyus-team__title">{member.title}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="whyus-team__note" data-reveal data-reveal-delay="640">
        Conoce al equipo completo en LUMISIS.
      </p>
    </Container>
  </Section>

  {/* Cómo trabajamos — las 4 D */}
  <Section>
    <Container>
      <p class="eyebrow mb-4" data-reveal>Nuestro proceso</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Cómo trabajamos</h2>
      <ol class="whyus-process" role="list">
        {process.map((step, i) => (
          <li
            class="whyus-process__step"
            data-reveal
            data-reveal-delay={`${120 + i * 100}`}
          >
            <span class="whyus-process__num">{String(i + 1).padStart(2, '0')}</span>
            <p class="whyus-process__label">{step.label}</p>
            <p class="whyus-process__copy">{step.copy}</p>
          </li>
        ))}
      </ol>
    </Container>
  </Section>

  {/* Por qué las empresas eligen LUMISIS — los cinco frentes + conteo integrado */}
  <Section class="whyus-rule">
    <Container>
      <div class="grid gap-16 md:grid-cols-2">
        <div class="whyus-enfoque__intro" data-reveal>
          <p class="eyebrow mb-4">¿Por Qué Nosotros?</p>
          <h2 class="text-3xl md:text-4xl">
            Por qué las empresas eligen LUMISIS&reg;
          </h2>
          <p class="mt-6 text-gray-600">
            Abordamos cada reto con intención, premeditación, planeación y un planteamiento estratégico — alineados a la estrategia del negocio en sus cinco plazos estratégicos.
          </p>
        </div>
        <div class="whyus-enfoque__list">
          <p class="eyebrow mb-6" data-reveal data-reveal-delay="100">Trabajamos en cinco frentes:</p>
          <ol class="why-us__list" role="list">
            {fronts.map((item, i) => (
              <li
                class="why-us__item"
                data-reveal
                data-reveal-delay={`${200 + i * 60}`}
              >
                <span class="why-us__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="why-us__label">{item}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <hr class="whyus-stats__divider" data-reveal />
      <div class="whyus-stats__grid">
        <div class="whyus-stat" data-reveal data-reveal-delay="120">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={5} prefix="+" suffix="k" />
          </span>
          <span class="whyus-stat__label">Talleres</span>
        </div>
        <div class="whyus-stat" data-reveal data-reveal-delay="200">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={50} prefix="+" suffix="k" />
          </span>
          <span class="whyus-stat__label">Horas de liberación de talento</span>
        </div>
        <div class="whyus-stat" data-reveal data-reveal-delay="280">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={400} prefix="+" />
          </span>
          <span class="whyus-stat__label">Conferencias</span>
        </div>
      </div>
    </Container>
  </Section>

  {/* Footprint — Alcance Global (brand-black, cierre editorial) */}
  <Section bg="dark" class="whyus-footprint">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Nuestra Huella</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Alcance Global</h2>
      <p class="whyus-footprint__intro" data-reveal data-reveal-delay="140">
        Hemos servido a clientes a nivel internacional, en cinco continentes.
      </p>

      <div
        class="whyus-footprint__stat"
        role="group"
        aria-label="Más de 30 países atendidos"
        data-reveal
        data-reveal-delay="200"
      >
        <span class="whyus-footprint__stat-num" aria-hidden="true">+30</span>
        <span class="whyus-footprint__stat-rule" aria-hidden="true"></span>
        <span class="whyus-footprint__stat-label" aria-hidden="true">Países atendidos</span>
      </div>

      <ul class="whyus-footprint__countries" role="list">
        {countries.map((name, i) => (
          <li
            class="whyus-footprint__country"
            data-reveal
            data-reveal-delay={`${220 + i * 22}`}
          >
            <span class="whyus-footprint__country-mark" aria-hidden="true"></span>
            <span class="whyus-footprint__country-name">{name}</span>
          </li>
        ))}
      </ul>

      <p class="whyus-footprint__note" data-reveal data-reveal-delay="500">
        Por mencionar algunos.
      </p>

      <ul class="whyus-footprint__detail" role="list" data-reveal data-reveal-delay="520">
        {clientTypes.map((type) => <li>{type}</li>)}
      </ul>

      <div class="whyus-footprint__cta" data-reveal data-reveal-delay="580">
        <a href={prefixBase('/contacto')} class="cta-pill cta-pill--solid" aria-label="Iniciar conversaci&oacute;n">
          <span class="letters">
            {'INICIAR CONVERSACIÓN'.split('').map((char, i) => (
              char === ' '
                ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
            ))}
          </span>
          <span class="cta-pill__arrow">&rarr;</span>
        </a>
        <a href={prefixBase('/soluciones')} class="cta-pill cta-pill--outline" aria-label="Ver soluciones">
          <span class="letters">
            {'VER SOLUCIONES'.split('').map((char, i) => (
              char === ' '
                ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
            ))}
          </span>
        </a>
      </div>
    </Container>
  </Section>
</PageLayout>
