---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { FootprintMap } from '@/components/islands/FootprintMap';
import { prefixBase, FOOTPRINT_COUNTRIES } from '@/lib/constants';
import { heroWhyUs, TEAM_MEMBERS } from '@/lib/images';

const fronts = [
  'Estratégico — alineados a la estrategia del negocio',
  'Funcional — de aplicación práctica y real',
  'Institucional — profesionalización y capacidades en un ambiente ESG',
  'Rentable — valor, ROI, ROE y crecimiento',
  'Personas — mindset, competencias y enfoque sistémico',
];

const process = [
  { label: 'Discover', copy: 'Nos adentramos en tu organización con una indagación apreciativa para entenderla a fondo.' },
  { label: 'Design', copy: 'Co-creamos un traje a la medida para los retos alineados a la estrategia, y materializamos un prototipo.' },
  { label: 'Deliver', copy: 'Entregamos la promesa diseñada con impecabilidad y potencia.' },
  { label: 'Develop', copy: 'Damos seguimiento y fortalecemos los resultados en el tiempo.' },
];
---

<PageLayout title="¿Por Qué Nosotros? — LUMISIS" description="Intención, propósito y resultados sin precedentes. Descubre por qué las empresas eligen LUMISIS.">
  {/* Hero */}
  <section class="hero-inner">
    <Image
      src={heroWhyUs}
      alt=""
      width={1920}
      quality={82}
      class="hero-inner__bg"
    />
    <div class="hero-inner__overlay"></div>
    <Container>
      <div class="hero-inner__content">
        <span class="hero-inner__eyebrow" data-reveal>¿Por Qué Nosotros?</span>
        <h1 class="hero-inner__title" lang="en" data-reveal data-reveal-delay="120">
          Resonant Strategic<br />Breakthroughs
        </h1>
        <p class="hero-inner__lede" data-reveal data-reveal-delay="280">
          Todo lo que hacemos es resonante, tiene eco y repercute de manera poderosa en las organizaciones, en las personas y en el planeta.
        </p>
      </div>
    </Container>
  </section>

  {/* Nuestro Equipo — mosaico sobre brand-black */}
  <Section bg="dark" class="whyus-team">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Expertos</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Nuestro Equipo</h2>
      <p class="whyus-team__intro max-w-xl" data-reveal data-reveal-delay="160">
        Un equipo multidisciplinario de alto perfil que hace fit con las necesidades de nuestros clientes — estrategas, consultores y coaches, expertos internacionales.
      </p>

      <div class="whyus-team__mosaic">
        {TEAM_MEMBERS.map((member, i) => (
          <div
            class="whyus-team__tile"
            data-reveal
            data-reveal-delay={`${200 + i * 80}`}
          >
            <Image
              src={member.image}
              alt=""
              width={600}
              quality={85}
              class="whyus-team__photo"
            />
            <div class="whyus-team__overlay"></div>
            <div class="whyus-team__content">
              <p class="whyus-team__name">{member.name}</p>
              <p class="whyus-team__title">{member.title}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* Cómo trabajamos — las 4 D */}
  <Section>
    <Container>
      <p class="eyebrow mb-4" data-reveal>Nuestro proceso</p>
      <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Cómo trabajamos</h2>
      <ol class="whyus-process" role="list">
        {process.map((step, i) => (
          <li
            class="whyus-process__step"
            data-reveal
            data-reveal-delay={`${120 + i * 100}`}
          >
            <span class="whyus-process__num">{String(i + 1).padStart(2, '0')}</span>
            <p class="whyus-process__label">{step.label}</p>
            <p class="whyus-process__copy">{step.copy}</p>
          </li>
        ))}
      </ol>
    </Container>
  </Section>

  {/* Por qué las empresas eligen LUMISIS — los cinco frentes + conteo integrado */}
  <Section class="whyus-rule">
    <Container>
      <div class="grid gap-16 md:grid-cols-2">
        <div class="whyus-enfoque__intro" data-reveal>
          <p class="eyebrow mb-4">¿Por Qué Nosotros?</p>
          <h2 class="text-3xl md:text-4xl">
            Por qué las empresas eligen LUMISIS&reg;
          </h2>
          <p class="mt-6 text-gray-600">
            Abordamos cada reto con intención, premeditación, planeación y un planteamiento estratégico — alineados a la estrategia del negocio en sus cinco plazos estratégicos.
          </p>
        </div>
        <div class="whyus-enfoque__list">
          <p class="eyebrow mb-6" data-reveal data-reveal-delay="100">Trabajamos en cinco frentes:</p>
          <ol class="why-us__list" role="list">
            {fronts.map((item, i) => (
              <li
                class="why-us__item"
                data-reveal
                data-reveal-delay={`${200 + i * 60}`}
              >
                <span class="why-us__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="why-us__label">{item}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <hr class="whyus-stats__divider" data-reveal />
      <div class="whyus-stats__grid">
        <div class="whyus-stat" data-reveal data-reveal-delay="120">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={5} prefix="+" suffix="k" />
          </span>
          <span class="whyus-stat__label">Talleres</span>
        </div>
        <div class="whyus-stat" data-reveal data-reveal-delay="200">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={50} prefix="+" suffix="k" />
          </span>
          <span class="whyus-stat__label">Horas de liberación de talento</span>
        </div>
        <div class="whyus-stat" data-reveal data-reveal-delay="280">
          <span class="whyus-stat__num">
            <AnimatedNumber client:visible end={400} prefix="+" />
          </span>
          <span class="whyus-stat__label">Conferencias</span>
        </div>
      </div>
    </Container>
  </Section>

  {/* Footprint — Alcance Global (brand-black, cierre con CTA) */}
  <Section bg="dark" class="whyus-footprint">
    <Container>
      <div class="whyus-footprint__grid">
        <div class="whyus-footprint__copy">
          <p class="eyebrow mb-4" data-reveal>Nuestra Huella</p>
          <h2 class="text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Alcance Global</h2>
          <p class="whyus-footprint__lead" data-reveal data-reveal-delay="160">
            Hemos servido a clientes a nivel internacional en más de <strong>30 países</strong> — México, Alemania, Francia, Suiza, Inglaterra, Kenia, Sudáfrica, Canadá, Estados Unidos, Colombia, Argentina, Brasil y Japón, por mencionar algunos. Desde multinacionales hasta PyMES, desde empresas que cotizan en bolsa hasta empresas familiares.
          </p>
          <div class="whyus-footprint__cta" data-reveal data-reveal-delay="240">
            <a href={prefixBase('/contacto')} class="cta-pill cta-pill--solid" aria-label="Iniciar conversaci&oacute;n">
              <span class="letters">
                {'INICIAR CONVERSACIÓN'.split('').map((char, i) => (
                  char === ' '
                    ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                    : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
                ))}
              </span>
              <span class="cta-pill__arrow">&rarr;</span>
            </a>
            <a href={prefixBase('/soluciones')} class="cta-pill cta-pill--outline" aria-label="Ver soluciones">
              <span class="letters">
                {'VER SOLUCIONES'.split('').map((char, i) => (
                  char === ' '
                    ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                    : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
                ))}
              </span>
            </a>
          </div>
        </div>
        <div class="whyus-footprint__map" data-reveal data-reveal-delay="120">
          <FootprintMap client:visible pins={FOOTPRINT_COUNTRIES} />
        </div>
      </div>
    </Container>
  </Section>
</PageLayout>
