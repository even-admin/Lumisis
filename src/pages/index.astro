---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import { Globe } from '@/components/islands/Globe';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { SERVICES, prefixBase, GLOBE_PINS } from '@/lib/constants';
import { heroHomeAlt, CLIENT_LOGOS, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.es;

// Toggle the logo marquee on/off. Keep false until the team confirms the
// final logo list — placeholder logos risk client-conflict optics.
const SHOW_LOGO_BAND = false;
---

<PageLayout title="LUMISIS — Strategy | Consulting | Coaching">
  {/* Hero — People-photo with dark overlay (LUMISIS brand-true, negative mode) */}
  <section class="hero-people">
    <Image
      src={heroHomeAlt}
      alt=""
      width={1920}
      quality={82}
      class="hero-people__bg"
    />
    <div class="hero-people__overlay"></div>
    <Container>
      <div class="hero-people__content">
        <span class="hero-people__eyebrow" data-reveal>Strategy &nbsp;|&nbsp; Consulting &nbsp;|&nbsp; Coaching</span>
        <h1 class="hero-people__title" data-reveal data-reveal-delay="120">
          Prosperar en la<br />incertidumbre.
        </h1>
        <p class="hero-people__lede" data-reveal data-reveal-delay="280">
          Liberamos el potencial de organizaciones, l&iacute;deres y culturas.
        </p>
        <div class="hero-people__cta" data-reveal data-reveal-delay="440">
          <a href={prefixBase('/contacto')} class="cta-pill cta-pill--solid" aria-label="Iniciar conversaci&oacute;n">
            <span class="letters">
              {'INICIAR CONVERSACIÓN'.split('').map((char, i) => (
                char === ' '
                  ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                  : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
              ))}
            </span>
            <span class="cta-pill__arrow">&rarr;</span>
          </a>
          <a href={prefixBase('/soluciones')} class="cta-pill cta-pill--outline">
            <span class="letters">
              {'VER SOLUCIONES'.split('').map((char, i) => (
                char === ' '
                  ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                  : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
              ))}
            </span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Intro — Quiénes Somos */}
  <section class="home-intro">
    <Container>
      <p class="eyebrow home-intro__eyebrow" data-reveal>Quiénes somos</p>
      <h2 class="home-intro__statement" data-reveal data-reveal-delay="120">
        Una firma de estrategia, consultoría y coaching para <span class="home-intro__mark" data-reveal data-reveal-delay="900">los momentos que definen el futuro</span> de una organización.
      </h2>
      <p class="home-intro__supporting" data-reveal data-reveal-delay="280">
        Trabajamos con CEOs, consejos y equipos directivos que enfrentan transiciones críticas: <em class="home-intro__chip">crecimiento acelerado</em>, <em class="home-intro__chip">sucesión</em>, <em class="home-intro__chip">reposicionamiento</em>, <em class="home-intro__chip">evolución cultural</em>. Lo que entregamos no son frameworks ni reportes — son decisiones claras, ejecución acompañada y resultados que perduran.
      </p>

      <div class="home-intro__pillars">
        {[
          { label: 'Strategy', copy: 'Decisiones de portafolio, mercado y modelo de negocio.' },
          { label: 'Consulting', copy: 'Planeación, ejecución y evolución organizacional.' },
          { label: 'Coaching', copy: 'Desarrollo de líderes y equipos de alto desempeño.' },
        ].map((p, i) => (
          <div
            class="home-intro__pillar"
            data-reveal
            data-reveal-delay={`${440 + i * 100}`}
          >
            <span class="home-intro__pillar-num">{String(i + 1).padStart(2, '0')}</span>
            <p class="home-intro__pillar-label">{p.label}</p>
            <p class="home-intro__pillar-copy">{p.copy}</p>
          </div>
        ))}
      </div>

      <a href={prefixBase('/por-que-nosotros')} class="home-intro__cta" data-reveal data-reveal-delay="740">
        <span class="home-intro__cta-label">Conoce nuestra propuesta</span>
        <span class="home-intro__cta-arrow">&rarr;</span>
      </a>
    </Container>
  </section>

  {SHOW_LOGO_BAND && (
  <section class="logo-marquee" aria-label="Trusted by">
    <Container>
      <p class="eyebrow logo-marquee__eyebrow">Trusted by</p>
    </Container>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--left">
        <div class="logo-marquee__copy">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
        <div class="logo-marquee__copy" aria-hidden="true">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
      </div>
    </div>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--right">
        <div class="logo-marquee__copy">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
        <div class="logo-marquee__copy" aria-hidden="true">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
      </div>
    </div>
  </section>
  )}

  {/* Stats */}
  <Section bg="dark">
    <Container>
      <div class="grid gap-8 text-center md:grid-cols-3">
        <div data-reveal>
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={800} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Companies</p>
        </div>
        <div data-reveal data-reveal-delay="80">
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={100} prefix="+" suffix="k" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Impacted Executives</p>
        </div>
        <div data-reveal data-reveal-delay="160">
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={33} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Countries</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* Resonant Breakthroughs */}
  <Section>
    <Container narrow>
      <div class="text-center" data-reveal>
        <p class="eyebrow mb-4">Resonant Strategic Breakthroughs</p>
        <h2 class="text-3xl md:text-4xl">
          Everything we do is resonant
        </h2>
        <p class="mx-auto mt-6 text-gray-600">
          Has an echo and a powerful impact on organizations, people and the planet.
        </p>
        <div class="mt-8">
          <Button href={prefixBase('/por-que-nosotros')} variant="secondary">Descubrir más</Button>
        </div>
      </div>
    </Container>
  </Section>

  {/* Services Grid */}
  <Section bg="light">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Soluciones</p>
      <h2 class="mb-12 text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Nuestros Servicios</h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => {
          const img = SERVICE_IMAGES[service.slug];
          return (
            <a
              href={prefixBase(`/soluciones/${service.slug}`)}
              class="service-card group"
            >
              {img && (
                <Image
                  src={img}
                  alt={service.title}
                  width={800}
                  quality={80}
                  class="service-card__img"
                />
              )}
              <div class="service-card__overlay" />
              <div class="service-card__content">
                <h3 class="service-card__title">{service.title}</h3>
                <span class="service-card__cta">
                  Explorar →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </Section>

  {/* Offices / Globe */}
  <Section bg="dark">
    <Container>
      <div class="text-center">
        <p class="eyebrow mb-4 text-gray-400">Encuéntranos</p>
        <h2 class="text-3xl md:text-4xl text-white">Nuestras Oficinas</h2>
      </div>
      <div class="mx-auto mt-8 aspect-square max-w-[600px]">
        <Globe client:visible pins={GLOBE_PINS} />
      </div>
      <div class="mt-8 text-center">
        <Button href={prefixBase('/contacto')} variant="secondary">Contáctanos</Button>
      </div>
    </Container>
  </Section>
</PageLayout>

<style>
  /* =========================================================
     Home Intro — Quiénes Somos
     Editorial statement + three-pillar grid + CTA
     ========================================================= */
  .home-intro {
    padding-top: 6rem;
    padding-bottom: 6rem;
    background: #fff;
  }

  @media (min-width: 768px) {
    .home-intro {
      padding-top: 9rem;
      padding-bottom: 9rem;
    }
  }

  .home-intro__eyebrow {
    margin-bottom: 1.5rem;
  }

  .home-intro__statement {
    font-family: var(--font-display, 'Gotham', sans-serif);
    font-size: clamp(1.75rem, 3.6vw, 3rem);
    line-height: 1.15;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #393938;
    max-width: 60rem;
    margin: 0;
  }

  .home-intro__mark {
    position: relative;
    color: #393938;
    background-image: linear-gradient(transparent 70%, rgba(0, 152, 219, 0.08) 70%);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    transition: background-size 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__mark::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 2px;
    background: #0098DB;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__mark.revealed {
    background-size: 100% 100%;
  }

  .home-intro__mark.revealed::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-intro__mark,
    .home-intro__mark::after { transition: none; }
    .home-intro__mark.revealed { background-size: 100% 100%; }
    .home-intro__mark.revealed::after { transform: scaleX(1); }
  }

  .home-intro__supporting {
    margin-top: 2rem;
    max-width: 48rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(57, 57, 56, 0.7);
  }

  .home-intro__chip {
    font-style: normal;
    font-weight: 500;
    color: #393938;
    border-bottom: 1px solid rgba(57, 57, 56, 0.25);
    transition:
      color 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-bottom-width 320ms cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
  }

  .home-intro__chip:hover {
    color: #0098DB;
    border-bottom-color: #0098DB;
    border-bottom-width: 1.5px;
  }

  .home-intro__pillars {
    margin-top: 4rem;
    display: grid;
    gap: 2.5rem;
    border-top: 1px solid rgba(57, 57, 56, 0.08);
    padding-top: 2.5rem;
  }

  @media (min-width: 768px) {
    .home-intro__pillars {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  .home-intro__pillar {
    position: relative;
    padding-left: 1.25rem;
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__pillar::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #0098DB;
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__pillar-num {
    display: block;
    font-family: var(--font-display, 'Gotham', sans-serif);
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(57, 57, 56, 0.3);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
    transition: color 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__pillar-label {
    position: relative;
    display: inline-block;
    font-family: var(--font-display, 'Gotham', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0098DB;
    margin-bottom: 0.75rem;
  }

  .home-intro__pillar-label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1.5px;
    background: #0098DB;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__pillar-copy {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #393938;
    margin: 0;
  }

  .home-intro__pillar:hover { transform: translateY(-4px); }
  .home-intro__pillar:hover::before { transform: scaleY(1); }
  .home-intro__pillar:hover .home-intro__pillar-num { color: #0098DB; }
  .home-intro__pillar:hover .home-intro__pillar-label::after { transform: scaleX(1); }

  @media (prefers-reduced-motion: reduce) {
    .home-intro__pillar,
    .home-intro__pillar::before,
    .home-intro__pillar-num,
    .home-intro__pillar-label::after { transition: none; }
    .home-intro__pillar:hover { transform: none; }
  }

  .home-intro__cta {
    margin-top: 3.5rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 500;
    color: #393938;
    text-decoration: none;
    transition: color 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__cta-label {
    position: relative;
  }

  .home-intro__cta-label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1.5px;
    background: #0098DB;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__cta-arrow {
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-intro__cta:hover { color: #0098DB; }
  .home-intro__cta:hover .home-intro__cta-label::after { transform: scaleX(1); }
  .home-intro__cta:hover .home-intro__cta-arrow { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .home-intro__cta,
    .home-intro__cta-arrow,
    .home-intro__cta-label::after { transition: none; }
    .home-intro__cta:hover .home-intro__cta-arrow { transform: none; }
  }

  /* =========================================================
     Logo Marquee — Trusted by
     Two rows drifting opposite directions on brand-black bg.
     Each track holds two .copy children, min-width:100vw each,
     guaranteeing the track is always wider than the viewport.
     ========================================================= */
  .logo-marquee {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background: #393938;
  }

  @media (min-width: 768px) {
    .logo-marquee {
      padding-top: 7.5rem;
      padding-bottom: 7.5rem;
    }
  }

  .logo-marquee__eyebrow {
    text-align: center;
    margin-bottom: 3rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .logo-marquee__viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
            mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .logo-marquee__viewport + .logo-marquee__viewport {
    margin-top: 2.5rem;
  }

  .logo-marquee__track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .logo-marquee__copy {
    display: flex;
    align-items: center;
    gap: 4rem;
    min-width: 100vw;
    justify-content: space-around;
    padding: 0 2rem;
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .logo-marquee__copy { gap: 2rem; padding: 0 1rem; }
  }

  .logo-marquee__track--left  { animation: marquee-left  60s linear infinite; }
  .logo-marquee__track--right { animation: marquee-right 75s linear infinite; }

  .logo-marquee__viewport:hover .logo-marquee__track {
    animation-play-state: paused;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .logo-marquee__logo {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 767px) {
    .logo-marquee__logo { height: 32px; }
  }

  .logo-marquee__logo:hover {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-marquee__track--left,
    .logo-marquee__track--right { animation: none; }
    .logo-marquee__viewport {
      overflow: visible;
      -webkit-mask-image: none;
              mask-image: none;
    }
    .logo-marquee__track {
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
    .logo-marquee__copy {
      flex-wrap: wrap;
      justify-content: center;
      min-width: 0;
      width: 100%;
      gap: 2rem;
    }
  }
</style>
