---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import { Globe } from '@/components/islands/Globe';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { SERVICES, prefixBase, GLOBE_PINS } from '@/lib/constants';
import { heroHomeAlt, CLIENT_LOGOS, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.es;
---

<PageLayout title="LUMISIS — Strategy | Consulting | Coaching">
  {/* Hero — People-photo with dark overlay (LUMISIS brand-true, negative mode) */}
  <section class="hero-people">
    <Image
      src={heroHomeAlt}
      alt=""
      width={1920}
      quality={82}
      class="hero-people__bg"
    />
    <div class="hero-people__overlay"></div>
    <Container>
      <div class="hero-people__content">
        <span class="hero-people__eyebrow" data-reveal>Strategy &nbsp;|&nbsp; Consulting &nbsp;|&nbsp; Coaching</span>
        <h1 class="hero-people__title" data-reveal data-reveal-delay="120">
          Prosperar en la<br />incertidumbre.
        </h1>
        <p class="hero-people__lede" data-reveal data-reveal-delay="280">
          Liberamos el potencial de organizaciones, l&iacute;deres y culturas.
        </p>
        <div class="hero-people__cta" data-reveal data-reveal-delay="440">
          <a href={prefixBase('/contacto')} class="cta-pill cta-pill--solid" aria-label="Iniciar conversaci&oacute;n">
            <span class="letters">
              {'INICIAR CONVERSACIÓN'.split('').map((char, i) => (
                char === ' '
                  ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                  : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
              ))}
            </span>
            <span class="cta-pill__arrow">&rarr;</span>
          </a>
          <a href={prefixBase('/soluciones')} class="cta-pill cta-pill--outline">
            <span class="letters">
              {'VER SOLUCIONES'.split('').map((char, i) => (
                char === ' '
                  ? <span class="letter" style={`--i:${i}`}>&nbsp;</span>
                  : <span class="letter" style={`--i:${i}`}><span>{char}</span><span>{char}</span></span>
              ))}
            </span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Logo Marquee — Trusted by */}
  <section class="logo-marquee" aria-label="Trusted by">
    <Container>
      <p class="eyebrow logo-marquee__eyebrow">Trusted by</p>
    </Container>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--left">
        {[...CLIENT_LOGOS, ...CLIENT_LOGOS].map((logo) => (
          <Image
            src={logo}
            alt=""
            aria-hidden="true"
            height={40}
            quality={85}
            class="logo-marquee__logo"
          />
        ))}
      </div>
    </div>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--right">
        {[...CLIENT_LOGOS, ...CLIENT_LOGOS].map((logo) => (
          <Image
            src={logo}
            alt=""
            aria-hidden="true"
            height={40}
            quality={85}
            class="logo-marquee__logo"
          />
        ))}
      </div>
    </div>
  </section>

  {/* Why Us Preview */}
  <Section>
    <Container>
      <div class="grid gap-16 md:grid-cols-2">
        <div data-reveal>
          <p class="eyebrow mb-4">¿Por Qué Nosotros?</p>
          <h2 class="text-3xl md:text-4xl">
            Why Companies Choose Lumisis®
          </h2>
          <p class="mt-6 text-gray-600">
            We approach things with intention, thoughtfulness, planning and a strategic mindset.
          </p>
        </div>
        <div>
          <p class="eyebrow mb-6" data-reveal data-reveal-delay="100">Our Advantages Include:</p>
          <ol class="why-us__list">
            {[
              'Clear, Actionable Strategy',
              'Proven Frameworks',
              'Hands-On Implementation',
              'Transparent Costs',
              'Design for Long-Term Growth',
            ].map((item, i) => (
              <li
                class="why-us__item"
                data-reveal
                data-reveal-delay={`${200 + i * 60}`}
              >
                <span class="why-us__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="why-us__label">{item}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </Container>
  </Section>

  {/* Stats */}
  <Section bg="dark">
    <Container>
      <div class="grid gap-8 text-center md:grid-cols-3">
        <div data-reveal>
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={800} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Companies</p>
        </div>
        <div data-reveal data-reveal-delay="80">
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={100} prefix="+" suffix="k" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Impacted Executives</p>
        </div>
        <div data-reveal data-reveal-delay="160">
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={33} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Countries</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* Resonant Breakthroughs */}
  <Section>
    <Container narrow>
      <div class="text-center" data-reveal>
        <p class="eyebrow mb-4">Resonant Strategic Breakthroughs</p>
        <h2 class="text-3xl md:text-4xl">
          Everything we do is resonant
        </h2>
        <p class="mx-auto mt-6 text-gray-600">
          Has an echo and a powerful impact on organizations, people and the planet.
        </p>
        <div class="mt-8">
          <Button href={prefixBase('/por-que-nosotros')} variant="secondary">Descubrir más</Button>
        </div>
      </div>
    </Container>
  </Section>

  {/* Services Grid */}
  <Section bg="light">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Soluciones</p>
      <h2 class="mb-12 text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Nuestros Servicios</h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => {
          const img = SERVICE_IMAGES[service.slug];
          return (
            <a
              href={prefixBase(`/soluciones/${service.slug}`)}
              class="service-card group"
            >
              {img && (
                <Image
                  src={img}
                  alt={service.title}
                  width={800}
                  quality={80}
                  class="service-card__img"
                />
              )}
              <div class="service-card__overlay" />
              <div class="service-card__content">
                <h3 class="service-card__title">{service.title}</h3>
                <span class="service-card__cta">
                  Explorar →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </Section>

  {/* Offices / Globe */}
  <Section bg="dark">
    <Container>
      <div class="text-center">
        <p class="eyebrow mb-4 text-gray-400">Encuéntranos</p>
        <h2 class="text-3xl md:text-4xl text-white">Nuestras Oficinas</h2>
      </div>
      <div class="mx-auto mt-8 aspect-square max-w-[600px]">
        <Globe client:visible pins={GLOBE_PINS} />
      </div>
      <div class="mt-8 text-center">
        <Button href={prefixBase('/contacto')} variant="secondary">Contáctanos</Button>
      </div>
    </Container>
  </Section>
</PageLayout>

<style>
  /* =========================================================
     Logo Marquee — Trusted by
     Two rows drifting opposite directions, pure CSS, no JS.
     ========================================================= */
  .logo-marquee {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background: #fff;
  }

  @media (min-width: 768px) {
    .logo-marquee {
      padding-top: 7.5rem;
      padding-bottom: 7.5rem;
    }
  }

  .logo-marquee__eyebrow {
    text-align: center;
    margin-bottom: 3rem;
    color: rgba(57, 57, 56, 0.6);
  }

  .logo-marquee__viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
            mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .logo-marquee__viewport + .logo-marquee__viewport {
    margin-top: 2.5rem;
  }

  .logo-marquee__track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    will-change: transform;
  }

  @media (max-width: 767px) {
    .logo-marquee__track { gap: 2rem; }
  }

  .logo-marquee__track--left  { animation: marquee-left  60s linear infinite; }
  .logo-marquee__track--right { animation: marquee-right 75s linear infinite; }

  .logo-marquee__viewport:hover .logo-marquee__track {
    animation-play-state: paused;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .logo-marquee__logo {
    height: 40px;
    width: auto;
    filter: grayscale(100%);
    opacity: 0.55;
    transition:
      filter 320ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 767px) {
    .logo-marquee__logo { height: 32px; }
  }

  .logo-marquee__logo:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-marquee__track--left,
    .logo-marquee__track--right { animation: none; }
    .logo-marquee__viewport {
      overflow: visible;
      -webkit-mask-image: none;
              mask-image: none;
    }
    .logo-marquee__track {
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 2rem;
    }
  }

  /* =========================================================
     Why Us — staggered reveal + per-row hover
     ========================================================= */
  .why-us__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .why-us__item {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.125rem 0;
    border-bottom: 1px solid rgba(57, 57, 56, 0.08);
    transition:
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .why-us__item:last-child {
    border-bottom: 0;
  }

  .why-us__num {
    font-family: var(--font-display, 'Gotham', sans-serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: rgba(57, 57, 56, 0.25);
    min-width: 2.5rem;
    transition: color 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .why-us__label {
    position: relative;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #393938;
  }

  .why-us__label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1.5px;
    background: #0098DB;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .why-us__item:hover {
    transform: translateX(4px);
    border-bottom-color: rgba(0, 152, 219, 0.35);
  }

  .why-us__item:hover .why-us__num {
    color: #0098DB;
  }

  .why-us__item:hover .why-us__label::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .why-us__item,
    .why-us__num,
    .why-us__label::after { transition: none; }
    .why-us__item:hover { transform: none; }
  }
</style>
