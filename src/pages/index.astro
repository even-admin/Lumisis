---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import { Globe } from '@/components/islands/Globe';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { SERVICES, prefixBase, GLOBE_PINS } from '@/lib/constants';
import { CLIENT_LOGOS, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.es;
---

<PageLayout title="LUMISIS — Strategy | Consulting | Coaching">
  {/* Hero — Editorial type-hero, no photo background */}
  <section class="hero-editorial">
    <Container>
      <div class="hero-editorial__grid">
        <div class="hero-editorial__marker">
          <span class="roman">I &mdash; Manifiesto</span>
        </div>
        <h1 class="hero-editorial__title">
          <span class="word" data-reveal><span class="word__light">Prosperar</span><span class="word__black">Prosperar</span></span>{' '}
          <span class="word" data-reveal data-reveal-delay="60"><span class="word__light">en</span><span class="word__black">en</span></span>{' '}
          <span class="word" data-reveal data-reveal-delay="120"><span class="word__light">la</span><span class="word__black">la</span></span><br />
          <span class="word" data-reveal data-reveal-delay="180"><span class="word__light">incertidumbre.</span><span class="word__black">incertidumbre.</span></span>
        </h1>
        <p class="hero-editorial__lede" data-reveal data-reveal-delay="320">
          Liberamos el potencial de organizaciones, l&iacute;deres y culturas. Sin recetas. Sin pirotecnia. Con intenci&oacute;n.
        </p>
        <div class="hero-editorial__cta" data-reveal data-reveal-delay="440">
          <a href={prefixBase('/contacto')} class="cta-fill">
            <span class="cta-fill__label">Iniciar conversaci&oacute;n</span>
            <span class="cta-fill__arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Pull-quote breakout */}
  <section class="pullquote-section">
    <Container narrow>
      <blockquote class="pullquote-section__quote" data-reveal>
        <span class="roman" style="margin-bottom: 2rem; display: inline-block;">II &mdash; Esencia</span>
        <p class="pullquote">Un eco, no una intervenci&oacute;n.</p>
        <footer class="pullquote-section__attribution">
          Resonancia sobre alcance. Impacto duradero sobre actividad visible.
        </footer>
      </blockquote>
    </Container>
  </section>

  {/* Client Logos */}
  <div class="border-y border-gray-200 py-12">
    <Container>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        {CLIENT_LOGOS.map((logo, i) => (
          <Image
            src={logo}
            alt={`Client ${i + 1}`}
            height={32}
            quality={85}
            class="h-8 w-auto opacity-50 grayscale transition-opacity hover:opacity-80"
          />
        ))}
      </div>
    </Container>
  </div>

  {/* Why Us Preview */}
  <Section>
    <Container>
      <div class="grid gap-16 md:grid-cols-2">
        <div data-reveal>
          <p class="eyebrow mb-4">¿Por Qué Nosotros?</p>
          <h2 class="text-3xl md:text-4xl">
            Why Companies Choose Lumisis®
          </h2>
          <p class="mt-6 text-gray-600">
            We approach things with intention, thoughtfulness, planning and a strategic mindset.
          </p>
        </div>
        <div data-reveal data-reveal-delay="200">
          <p class="eyebrow mb-6">Our Advantages Include:</p>
          <ol class="space-y-4">
            {[
              'Clear, Actionable Strategy',
              'Proven Frameworks',
              'Hands-On Implementation',
              'Transparent Costs',
              'Design for Long-Term Growth',
            ].map((item, i) => (
              <li class="flex items-baseline gap-4">
                <span class="font-display text-2xl text-gray-300">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-lg font-medium">{item}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </Container>
  </Section>

  {/* Stats */}
  <Section bg="dark">
    <Container>
      <div class="grid gap-8 text-center md:grid-cols-3">
        <div data-reveal>
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={800} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Companies</p>
        </div>
        <div data-reveal data-reveal-delay="80">
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={100} prefix="+" suffix="k" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Impacted Executives</p>
        </div>
        <div data-reveal data-reveal-delay="160">
          <p class="font-display text-5xl">
            <AnimatedNumber client:visible end={33} prefix="+" />
          </p>
          <p class="mt-2 text-sm tracking-wider uppercase text-gray-400">Countries</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* Resonant Breakthroughs */}
  <Section>
    <Container narrow>
      <div class="text-center" data-reveal>
        <p class="eyebrow mb-4">Resonant Strategic Breakthroughs</p>
        <h2 class="text-3xl md:text-4xl">
          Everything we do is resonant
        </h2>
        <p class="mx-auto mt-6 text-gray-600">
          Has an echo and a powerful impact on organizations, people and the planet.
        </p>
        <div class="mt-8">
          <Button href={prefixBase('/por-que-nosotros')} variant="secondary">Descubrir más</Button>
        </div>
      </div>
    </Container>
  </Section>

  {/* Services Grid */}
  <Section bg="light">
    <Container>
      <p class="eyebrow mb-4" data-reveal>Soluciones</p>
      <h2 class="mb-12 text-3xl md:text-4xl" data-reveal data-reveal-delay="80">Nuestros Servicios</h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => {
          const img = SERVICE_IMAGES[service.slug];
          return (
            <a
              href={prefixBase(`/soluciones/${service.slug}`)}
              class="service-card group"
            >
              {img && (
                <Image
                  src={img}
                  alt={service.title}
                  width={800}
                  quality={80}
                  class="service-card__img"
                />
              )}
              <div class="service-card__overlay" />
              <div class="service-card__content">
                <h3 class="service-card__title">{service.title}</h3>
                <span class="service-card__cta">
                  Explorar →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </Section>

  {/* Offices / Globe */}
  <Section bg="dark">
    <Container>
      <div class="text-center">
        <p class="eyebrow mb-4 text-gray-400">Encuéntranos</p>
        <h2 class="text-3xl md:text-4xl text-white">Nuestras Oficinas</h2>
      </div>
      <div class="mx-auto mt-8 aspect-square max-w-[600px]">
        <Globe client:visible pins={GLOBE_PINS} />
      </div>
      <div class="mt-8 text-center">
        <Button href={prefixBase('/contacto')} variant="secondary">Contáctanos</Button>
      </div>
    </Container>
  </Section>
</PageLayout>
