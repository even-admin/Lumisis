---
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import { Globe } from '@/components/islands/Globe';
import { AnimatedNumber } from '@/components/islands/AnimatedNumber';
import { SERVICES, prefixBase, GLOBE_PINS } from '@/lib/constants';
import { heroHomeAlt, CLIENT_LOGOS, SERVICE_IMAGES } from '@/lib/images';

const services = SERVICES.es;

// Toggle the logo marquee on/off. Keep false until the team confirms the
// final logo list — placeholder logos risk client-conflict optics.
const SHOW_LOGO_BAND = false;
---

<PageLayout title="LUMISIS — Strategy | Consulting | Coaching">
  {/* Hero — People-photo with dark overlay (LUMISIS brand-true, negative mode) */}
  <section class="hero-people">
    <Image
      src={heroHomeAlt}
      loading="eager"
      fetchpriority="high"
      alt=""
      widths={[480, 1024, 1920]}
      sizes="(max-width: 767px) 480px, 100vw"
      quality={82}
      class="hero-people__bg"
    />
    <div class="hero-people__overlay"></div>
    <Container>
      <div class="hero-people__content">
        <span class="hero-people__eyebrow" data-reveal>Strategy &nbsp;|&nbsp; Consulting &nbsp;|&nbsp; Coaching</span>
        <h1 class="hero-people__title" data-reveal data-reveal-delay="120">
          Prosperar en la<br />incertidumbre
        </h1>
        <p class="hero-people__lede" data-reveal data-reveal-delay="280">
          Liberamos el potencial de las organizaciones y las personas.
        </p>
      </div>
    </Container>
  </section>

  {/* Intro — Quiénes Somos */}
  <section class="home-intro">
    <Container>
      <p class="eyebrow home-intro__eyebrow" data-reveal>Quiénes somos</p>
      <h2 class="home-intro__statement" data-reveal data-reveal-delay="120">
        Una firma que reta la estrategia, instala mejores prácticas y <span class="home-intro__mark">libera el potencial de las personas</span>.
      </h2>
      <p class="home-intro__supporting" data-reveal data-reveal-delay="280">
        Acompañamos a empresarios y directivos en sus momentos críticos: institucionalización, sucesión, crecimiento acelerado, evolución cultural, entre otros.
      </p>
      <p class="home-intro__supporting" data-reveal data-reveal-delay="360">
        Servimos a nuestros clientes con expertos internacionales acostumbrados a retar el status quo y acelerar el espiral de aprendizaje.
      </p>

      <div class="home-intro__pillars">
        {[
          { label: 'Estrategia', copy: 'Planeación, alineación, cascadeo, despliegue y rendición de cuentas.' },
          { label: 'Consultoría', copy: 'Consultoría y mejores prácticas para institucionalizar el negocio.' },
          { label: 'Coaching', copy: 'Coaching y liberación de talento para líderes y equipos.' },
        ].map((p, i) => (
          <div
            class="home-intro__pillar"
            data-reveal
            data-reveal-delay={`${440 + i * 100}`}
          >
            <span class="home-intro__pillar-num">{String(i + 1).padStart(2, '0')}</span>
            <p class="home-intro__pillar-label">{p.label}</p>
            <p class="home-intro__pillar-copy">{p.copy}</p>
          </div>
        ))}
      </div>

      <a href={prefixBase('/por-que-nosotros')} class="home-intro__cta" data-reveal data-reveal-delay="740">
        <span class="home-intro__cta-label">Conoce nuestra propuesta</span>
        <span class="home-intro__cta-arrow">&rarr;</span>
      </a>
    </Container>
  </section>

  {SHOW_LOGO_BAND && (
  <section class="logo-marquee" aria-label="Trusted by">
    <Container>
      <p class="eyebrow logo-marquee__eyebrow">Trusted by</p>
    </Container>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--left">
        <div class="logo-marquee__copy">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
        <div class="logo-marquee__copy" aria-hidden="true">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
      </div>
    </div>

    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track logo-marquee__track--right">
        <div class="logo-marquee__copy">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
        <div class="logo-marquee__copy" aria-hidden="true">
          {CLIENT_LOGOS.map((logo) => (
            <Image
              src={logo}
              alt=""
              aria-hidden="true"
              height={40}
              quality={85}
              class="logo-marquee__logo"
            />
          ))}
        </div>
      </div>
    </div>
  </section>
  )}

  {/* Presencia Global — merged Offices + Stats editorial composition */}
  <section class="presencia" id="presencia">
    <Container>
      <div class="presencia__grid">
        <div class="presencia__col presencia__col--left">
          <p class="presencia__eyebrow" data-reveal>Footprint</p>
          <h2 class="presencia__title" data-reveal data-reveal-delay="120">Impacto global</h2>
          <p class="presencia__lede" data-reveal data-reveal-delay="200">
            Más de 20 años acompañando organizaciones en más de 30 países.
          </p>
          <div class="presencia__globe">
            <Globe client:visible pins={GLOBE_PINS} showLabels={false} pinSize={0.008} />
          </div>
        </div>

        <div class="presencia__content">
          <ul class="presencia__stats">
            <li class="presencia-stat" data-reveal data-reveal-delay="240">
              <span class="presencia-stat__num">
                <AnimatedNumber client:visible end={800} prefix="+" />
              </span>
              <span class="presencia-stat__label">Compañías transformadas</span>
            </li>
            <li class="presencia-stat" data-reveal data-reveal-delay="320">
              <span class="presencia-stat__num">
                <AnimatedNumber client:visible end={100} prefix="+" suffix="k" />
              </span>
              <span class="presencia-stat__label">Ejecutivos impactados</span>
            </li>
            <li class="presencia-stat" data-reveal data-reveal-delay="400">
              <span class="presencia-stat__num">
                <AnimatedNumber client:visible end={30} prefix="+" />
              </span>
              <span class="presencia-stat__label">Países</span>
            </li>
          </ul>

          <hr class="presencia__divider" data-reveal data-reveal-delay="520" />

          <div class="presencia__offices">
            <p class="presencia__offices-label" data-reveal data-reveal-delay="600">Oficinas</p>
            <ul class="presencia__cities">
              <li data-reveal data-reveal-delay="680"><span class="city__name">Mérida</span><span class="city__region">México · HQ</span></li>
              <li data-reveal data-reveal-delay="740"><span class="city__name">Ciudad de México</span><span class="city__region">México</span></li>
              <li data-reveal data-reveal-delay="800"><span class="city__name">Chihuahua</span><span class="city__region">México</span></li>
              <li data-reveal data-reveal-delay="860"><span class="city__name">San Diego</span><span class="city__region">Estados Unidos</span></li>
              <li data-reveal data-reveal-delay="920"><span class="city__name">Berlín</span><span class="city__region">Alemania</span></li>
            </ul>
          </div>

          <a href={prefixBase('/contacto')} class="presencia__cta" data-reveal data-reveal-delay="1040">
            <span class="presencia__cta-label">Habla con un experto</span>
            <span class="presencia__cta-arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Services — Asymmetric Bento Mosaic */}
  <section class="services">
    <Container>
      <div class="services__header">
        <p class="services__eyebrow" data-reveal>Soluciones</p>
        <h2 class="services__title" data-reveal data-reveal-delay="120">Nuestros Servicios</h2>
      </div>

      <div class="services__mosaic">
        {services.map((service, i) => {
          const img = SERVICE_IMAGES[service.slug];
          return (
            <a
              href={prefixBase(`/soluciones/${service.slug}`)}
              class="service-tile"
              data-reveal
              data-reveal-delay={`${240 + i * 80}`}
            >
              {img && (
                <Image
                  src={img}
                  alt={service.title}
                  width={800}
                  quality={80}
                  class="service-tile__img"
                />
              )}
              <div class="service-tile__overlay"></div>
              <div class="service-tile__content">
                <h3 class="service-tile__title">{service.title}</h3>
                <span class="service-tile__cta">
                  <span class="service-tile__cta-label">Explorar</span>
                  <span class="service-tile__cta-arrow">&rarr;</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </section>

</PageLayout>

<script>
  // Single, persistent scroll listener — re-queries marks each tick so View
  // Transitions just work without leaking listeners across navigations.
  (function initMarkProgress() {
    function update() {
      const marks = document.querySelectorAll<HTMLElement>('.home-intro__mark');
      if (!marks.length) return;
      const vh = window.innerHeight;
      const startY = vh * 0.90; // phrase top here → progress 0
      const endY = vh * 0.30;   // phrase top here → progress 1
      const span = startY - endY;
      for (const mark of marks) {
        const rect = mark.getBoundingClientRect();
        const raw = (startY - rect.top) / span;
        const progress = raw < 0 ? 0 : raw > 1 ? 1 : raw;
        mark.style.setProperty('--mark-progress', progress.toString());
      }
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    document.addEventListener('astro:page-load', update);
    update();
  })();
</script>
