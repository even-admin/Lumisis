---

<div id="preloader" class="preloader" aria-hidden="true">
  <p class="preloader__text">LUMISIS</p>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-dark, #0A0A0A);
    animation: preloader-bg-out 400ms cubic-bezier(0.16, 1, 0.3, 1) 1.6s forwards;
    pointer-events: none;
  }

  .preloader.preloader--skip {
    display: none;
  }

  .preloader__text {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-on-dark, #FBFAFC);
    animation:
      preloader-text-in 600ms cubic-bezier(0.16, 1, 0.3, 1) forwards,
      preloader-text-out 400ms cubic-bezier(0.7, 0, 0.84, 0) 1.2s forwards;
  }

  @keyframes preloader-text-in {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes preloader-text-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-40px);
    }
  }

  @keyframes preloader-bg-out {
    to {
      opacity: 0;
      visibility: hidden;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .preloader {
      animation: preloader-bg-out 0ms 200ms forwards;
    }

    .preloader__text {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script is:inline>
  (function() {
    var el = document.getElementById('preloader');
    if (!el) return;
    if (sessionStorage.getItem('preloaderShown')) {
      el.classList.add('preloader--skip');
    } else {
      sessionStorage.setItem('preloaderShown', '1');
    }
  })();
</script>
