---
import { NAV_ITEMS, SOCIAL_LINKS, SITE } from '@/lib/constants';
import { getLocaleFromUrl } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import Container from './Container.astro';

const locale = getLocaleFromUrl(Astro.url);
const navItems = NAV_ITEMS[locale];
---

<footer class="footer" transition:persist>
  <Container>
    <div class="footer__grid">
      <div class="footer__brand">
        <p class="footer__logo">LUMISIS</p>
        <p class="footer__tagline">Strategy | Consulting | Coaching</p>
      </div>

      <div class="footer__right">
        <div class="footer__col">
          <p class="footer__heading">{ui[locale]['footer.nav']}</p>
          <nav class="footer__nav" aria-label="Footer navigation">
            {navItems.map((item) => (
              <a href={item.href} class="footer__link">
                {item.label}
              </a>
            ))}
          </nav>
        </div>

        <div class="footer__col">
          <p class="footer__heading">{ui[locale]['footer.connect']}</p>
          <div class="footer__nav">
            {SOCIAL_LINKS.map((link) => (
              <a
                href={link.href}
                class="footer__link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">{SITE.copyright}</p>
    </div>
  </Container>
</footer>

<style>
  .footer {
    background-color: var(--color-surface-dark, #0A0A0A);
    color: var(--color-text-on-dark, #FBFAFC);
    padding: 5rem 0 2.5rem;
  }

  .footer__grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted-dark, #999);
    letter-spacing: 0.05em;
  }

  .footer__right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .footer__right {
      justify-items: end;
    }
  }

  .footer__heading {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted-dark, #999);
    margin-bottom: 1rem;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__link:hover {
    color: white;
  }

  .footer__bottom {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-dark, rgba(255, 255, 255, 0.1));
  }

  .footer__copyright {
    font-size: 0.75rem;
    color: var(--color-text-muted-dark, #999);
    letter-spacing: 0.05em;
  }
</style>
