---
interface Props {
  as?: 'div' | 'section' | 'article' | 'main' | 'nav' | 'footer';
  class?: string;
  narrow?: boolean;
}

const { as: Tag = 'div', class: className, narrow = false } = Astro.props;
---

<Tag
  class:list={[
    'mx-auto w-full px-6 md:px-8',
    narrow ? 'max-w-[65rem]' : 'max-w-[80rem]',
    className,
  ]}
>
  <slot />
</Tag>
