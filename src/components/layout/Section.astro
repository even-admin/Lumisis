---
interface Props {
  id?: string;
  class?: string;
  bg?: 'white' | 'light' | 'dark';
}

const { id, class: className, bg = 'white' } = Astro.props;

const bgClasses: Record<string, string> = {
  white: 'bg-white',
  light: 'bg-gray-50',
  dark: 'bg-[var(--color-surface-dark)] text-[var(--color-text-on-dark)]',
};
---

<section
  id={id}
  class:list={[
    'section-padding',
    bgClasses[bg],
    className,
  ]}
>
  <slot />
</section>
