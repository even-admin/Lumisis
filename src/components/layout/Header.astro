---
import { Image } from 'astro:assets';
import { NAV_ITEMS, prefixBase } from '@/lib/constants';
import { getLocaleFromUrl, getTranslatedPath } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import { lumisisLogoWhite, lumisisLogoColor } from '@/lib/images';

const locale = getLocaleFromUrl(Astro.url);
const navItems = NAV_ITEMS[locale];
const alternatePath = getTranslatedPath(Astro.url.pathname);
const switchLabel = ui[locale]['lang.switch'];
const switchAriaLabel = ui[locale]['lang.label'];
const homeHref = locale === 'es' ? prefixBase('/') : prefixBase('/en/');
const contactHref = locale === 'es' ? prefixBase('/contacto') : prefixBase('/en/contact');
const contactLabel = locale === 'es' ? 'Contáctanos' : 'Contact';
const menuLabel = locale === 'es' ? 'Menú' : 'Menu';
---

<header class="header" id="site-header" transition:persist>
  {/* Brand-gradient accent strip — institutional signifier */}
  <div class="header__accent" aria-hidden="true"></div>

  <nav class="header__inner" aria-label="Main navigation">
    {/* Logo — two stacked images, swap via opacity (white over hero, full color on scroll) */}
    <a href={homeHref} class="header__logo" aria-label="LUMISIS — Home">
      <Image
        src={lumisisLogoWhite}
        alt="LUMISIS"
        height={32}
        class="header__logo-img header__logo-img--white"
      />
      <Image
        src={lumisisLogoColor}
        alt=""
        aria-hidden="true"
        height={32}
        class="header__logo-img header__logo-img--color"
      />
    </a>

    {/* Center nav links — visible only in default (over hero) state on desktop */}
    <ul class="header__links" role="list">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="header__link">{item.label}</a>
        </li>
      ))}
    </ul>

    {/* Right side: lang + CTA (full-state) OR Menu button (compact-state / mobile) */}
    <div class="header__end">
      <a
        href={alternatePath}
        class="header__lang"
        aria-label={switchAriaLabel}
      >
        {switchLabel}
      </a>

      <a href={contactHref} class="header__cta">
        <span>{contactLabel}</span>
        <span class="header__cta-arrow" aria-hidden="true">&rarr;</span>
      </a>

      <button
        class="header__menu-btn"
        aria-label={`Open ${menuLabel}`}
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="mobile-menu-toggle"
        type="button"
      >
        <span class="header__menu-bars" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
        <span class="header__menu-label">{menuLabel}</span>
      </button>
    </div>
  </nav>
</header>

{/* Mobile menu lives OUTSIDE the header so its position:fixed resolves
    against the viewport, not against the header (which has backdrop-filter
    in its solid state, creating a containing block that would scope the
    menu to the header's tiny height). */}
<div id="mobile-menu" class="mobile-menu" aria-hidden="true" transition:persist>
  <div class="mobile-menu__accent" aria-hidden="true"></div>
  <div class="mobile-menu__top">
    <a href={homeHref} class="header__logo" aria-label="LUMISIS — Home">
      <Image src={lumisisLogoColor} alt="LUMISIS" height={32} class="mobile-menu__logo-img" />
    </a>
    <button
      aria-label="Close menu"
      id="mobile-menu-close"
      type="button"
      class="mobile-menu__close"
    >
      <span></span>
      <span></span>
    </button>
  </div>
  <nav class="mobile-menu__nav" aria-label="Mobile navigation">
    {navItems.map((item, i) => (
      <a href={item.href} class="mobile-menu__link" style={`--i:${i}`}>
        <span class="mobile-menu__link-num">0{i + 1}</span>
        <span class="mobile-menu__link-label">{item.label}</span>
      </a>
    ))}
  </nav>
  <div class="mobile-menu__footer">
    <a href={alternatePath} class="mobile-menu__lang">{switchLabel}</a>
    <a href={contactHref} class="mobile-menu__cta">
      {contactLabel} &rarr;
    </a>
  </div>
</div>

<style>
  /* ============================================================
     Header — Transparent over hero → Compact white on scroll
     Institutional nav. Gets out of the way once you scroll.
     ============================================================ */

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background-color: transparent;
    transition:
      background-color 320ms cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 320ms cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: 1px solid transparent;
  }

  .header--solid {
    background-color: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom-color: rgba(57, 57, 56, 0.08);
  }

  /* Brand-gradient accent strip — top edge of the header */
  .header__accent {
    height: 3px;
    width: 100%;
    background: linear-gradient(
      90deg,
      #F5B335 0%,
      #E43D30 25%,
      #aa5b5e 50%,
      #009ADE 75%,
      #6ABF4B 100%
    );
    transition: height 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Compact state: thinner accent strip */
  .header--solid .header__accent {
    height: 2px;
  }

  /* ── Inner nav layout ─────────────────────────────────────── */

  .header__inner {
    max-width: var(--max-width-site, 80rem);
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 1.5rem;
    transition: padding 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 768px) {
    .header__inner {
      padding: 1.75rem 2rem;
      gap: 3rem;
    }
  }

  @media (min-width: 1280px) {
    .header__inner {
      padding: 1.75rem 2.5rem;
    }
  }

  /* Compact state — significantly reduced padding (and smaller logo via CSS below) */
  .header--solid .header__inner {
    padding-top: 0.875rem;
    padding-bottom: 0.875rem;
  }

  /* ── Logo — two stacked images, opacity swap ──────────────── */

  .header__logo {
    position: relative;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    height: 32px;
    grid-column: 1;
    justify-self: start;
    transition: height 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__logo-img {
    height: 32px;
    width: auto;
    transition:
      opacity 320ms cubic-bezier(0.16, 1, 0.3, 1),
      height 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__logo-img--white {
    opacity: 1;
  }

  .header__logo-img--color {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    opacity: 0;
  }

  /* Solid state: swap to color logo + shrink */
  .header--solid .header__logo,
  .header--solid .header__logo-img {
    height: 28px;
  }

  .header--solid .header__logo-img--white {
    opacity: 0;
  }

  .header--solid .header__logo-img--color {
    opacity: 1;
  }

  /* ── Center nav links — desktop only, hidden when solid ───── */

  .header__links {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    grid-column: 2;
    justify-self: center;
  }

  @media (min-width: 960px) {
    .header__links {
      display: flex;
    }
    .header--solid .header__links {
      display: none;
    }
  }

  .header__link {
    position: relative;
    display: inline-block;
    padding: 0.25rem 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.005em;
    text-transform: none;
    text-decoration: none;
    color: #FFFFFF;
    transition: color 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Brand-blue underline slides in from left on hover */
  .header__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 2px;
    background-color: var(--color-brand-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__link:hover::after,
  .header__link:focus-visible::after {
    transform: scaleX(1);
  }

  /* ── Right side end-group ─────────────────────────────────── */

  .header__end {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    grid-column: 3;
    justify-self: end;
  }

  @media (min-width: 768px) {
    .header__end {
      gap: 1.5rem;
    }
  }

  /* Lang switcher — visible only in default desktop state */
  .header__lang {
    display: none;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.85);
    transition: color 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 960px) {
    .header__lang {
      display: inline-block;
    }
    .header--solid .header__lang {
      display: none;
    }
  }

  .header__lang:hover {
    color: #FFFFFF;
  }

  /* Contact CTA pill — visible only in default desktop state */
  .header__cta {
    display: none;
    align-items: center;
    gap: 0.625rem;
    padding: 0.6875rem 1.375rem;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    background-color: transparent;
    color: #FFFFFF;
    border: 1px solid rgba(255, 255, 255, 0.85);
    transition:
      background-color 280ms cubic-bezier(0.16, 1, 0.3, 1),
      color 280ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 960px) {
    .header__cta {
      display: inline-flex;
    }
    .header--solid .header__cta {
      display: none;
    }
  }

  .header__cta:hover {
    background-color: var(--color-brand-blue);
    border-color: var(--color-brand-blue);
    color: #FFFFFF;
  }

  .header__cta-arrow {
    display: inline-block;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__cta:hover .header__cta-arrow {
    transform: translateX(4px);
  }

  /* ── Menu button — appears when compact (solid state) OR on mobile ── */

  .header__menu-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem 0.5rem 0.625rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #FFFFFF;
    transition: color 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 960px) {
    .header__menu-btn {
      display: none;
    }
    .header--solid .header__menu-btn {
      display: inline-flex;
    }
  }

  /* When in solid state, menu button text is brand-black */
  .header--solid .header__menu-btn {
    color: var(--color-brand-black);
  }

  .header__menu-btn:hover {
    color: var(--color-brand-blue);
  }

  .header--solid .header__menu-btn:hover {
    color: var(--color-brand-blue);
  }

  /* Two-bar icon (institutional, not 3-bar hamburger) */
  .header__menu-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .header__menu-bars > span {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: currentColor;
    transition: width 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__menu-bars > span:nth-child(2) {
    width: 60%;
    margin-left: auto;
  }

  .header__menu-btn:hover .header__menu-bars > span:nth-child(2) {
    width: 100%;
  }

  .header__menu-label {
    display: none;
  }

  @media (min-width: 640px) {
    .header__menu-label {
      display: inline-block;
    }
  }

  /* ============================================================
     Mobile / Compact Menu Drawer — Full-screen overlay
     ============================================================ */

  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    z-index: 60;
    background-color: #FFFFFF;
    display: none;
    flex-direction: column;
  }

  .mobile-menu--open {
    display: flex;
  }

  .mobile-menu__accent {
    height: 3px;
    width: 100%;
    background: linear-gradient(
      90deg,
      #F5B335 0%,
      #E43D30 25%,
      #aa5b5e 50%,
      #009ADE 75%,
      #6ABF4B 100%
    );
  }

  .mobile-menu__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.5rem;
    border-bottom: 1px solid rgba(57, 57, 56, 0.06);
  }

  .mobile-menu__logo-img {
    height: 32px;
    width: auto;
  }

  .mobile-menu__close {
    position: relative;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .mobile-menu__close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 1.5px;
    background-color: var(--color-brand-black);
  }

  .mobile-menu__close span:nth-child(1) {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .mobile-menu__close span:nth-child(2) {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .mobile-menu__nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 3rem 1.5rem 2rem;
    gap: 0;
  }

  .mobile-menu__link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    text-decoration: none;
    color: var(--color-brand-black);
    border-bottom: 1px solid rgba(57, 57, 56, 0.08);
    transition: padding 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu__link:hover {
    padding-left: 0.5rem;
  }

  .mobile-menu__link-num {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-brand-blue);
  }

  .mobile-menu__link-label {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .mobile-menu__link-label {
      font-size: 2.5rem;
    }
  }

  .mobile-menu__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.5rem 2rem;
    border-top: 1px solid rgba(57, 57, 56, 0.08);
  }

  .mobile-menu__lang {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-gray-60, #7C7C7B);
  }

  .mobile-menu__cta {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-brand-blue);
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    if (!header) return;

    // ── Menu open/close (works for both mobile burger and desktop compact-state Menu button) ──
    toggle?.addEventListener('click', () => {
      menu?.classList.add('mobile-menu--open');
      menu?.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    });

    close?.addEventListener('click', () => {
      menu?.classList.remove('mobile-menu--open');
      menu?.setAttribute('aria-hidden', 'true');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });

    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('mobile-menu--open');
        menu.setAttribute('aria-hidden', 'true');
        toggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });

    // ── Transparent → solid on first scroll (not after full hero exit) ──
    // Uses both scroll events AND a rAF polling fallback for robustness
    // against smooth-scroll libraries (like Lenis) that may not always
    // dispatch native scroll events.
    const darkHero = document.querySelector(
      '.hero-people, [data-dark-hero]'
    );
    const SCROLL_THRESHOLD = 8;

    function updateHeaderState() {
      if (!darkHero) {
        header.classList.add('header--solid');
        return;
      }
      header.classList.toggle(
        'header--solid',
        window.scrollY > SCROLL_THRESHOLD,
      );
    }

    // Clean up any previous listener / poll loop from an earlier initHeader call
    if (header._stopPoll) header._stopPoll();
    if (header._scrollListener) {
      window.removeEventListener('scroll', header._scrollListener);
    }

    // 1) Native scroll event listener (covers normal scrolls)
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateHeaderState();
          ticking = false;
        });
        ticking = true;
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    header._scrollListener = onScroll;

    // 2) rAF poll fallback (covers Lenis or other libs that may not fire native scroll)
    let lastScrollY = -1;
    let stopped = false;
    function poll() {
      if (stopped) return;
      const y = window.scrollY;
      if (y !== lastScrollY) {
        lastScrollY = y;
        updateHeaderState();
      }
      requestAnimationFrame(poll);
    }
    header._stopPoll = () => {
      stopped = true;
    };
    poll();

    // Set initial state immediately
    updateHeaderState();
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);

  document.addEventListener('astro:after-swap', () => {
    const menu = document.getElementById('mobile-menu');
    const toggle = document.getElementById('mobile-menu-toggle');
    menu?.classList.remove('mobile-menu--open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  });
</script>
