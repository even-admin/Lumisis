---
import PageLayout from './PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import { prefixBase } from '@/lib/constants';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
  relatedServices: Array<{ title: string; slug: string }>;
}

const { title, description, lang, relatedServices } = Astro.props;
const solutionsBase = prefixBase(lang === 'es' ? '/soluciones' : '/en/solutions');
const solutionsLabel = lang === 'es' ? 'Soluciones en Movimiento' : 'Solutions in Motion';
const backLabel = lang === 'es' ? '← Todas las soluciones' : '← All solutions';
---

<PageLayout title={`${title} — LUMISIS`} description={description}>
  {/* Hero */}
  <section class="flex min-h-[50vh] items-end bg-gray-100 pb-16">
    <Container>
      <a href={solutionsBase} class="eyebrow mb-4 inline-block no-underline hover:text-brand-black">
        {backLabel}
      </a>
      <h1 class="text-4xl md:text-5xl">{title}</h1>
    </Container>
  </section>

  {/* Content */}
  <Section>
    <Container narrow>
      <article class="prose prose-lg max-w-none [&>h2]:font-display [&>h2]:text-3xl [&>h2]:mt-0 [&>p]:text-gray-600">
        <slot />
      </article>
    </Container>
  </Section>

  {/* Related Services */}
  {relatedServices.length > 0 && (
    <Section bg="light">
      <Container>
        <p class="eyebrow mb-8">{solutionsLabel}</p>
        <div class="grid gap-6 sm:grid-cols-2">
          {relatedServices.map((related) => (
            <a
              href={`${solutionsBase}/${related.slug}`}
              class="group block border border-gray-200 bg-white p-8 no-underline transition-colors hover:border-brand-black"
            >
              <h3 class="text-xl">{related.title}</h3>
              <span class="mt-4 inline-block text-sm text-gray-500 transition-colors group-hover:text-brand-black">
                {lang === 'es' ? 'Explorar →' : 'Explore →'}
              </span>
            </a>
          ))}
        </div>
      </Container>
    </Section>
  )}
</PageLayout>
