---
import { Image } from 'astro:assets';
import PageLayout from './PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import { prefixBase } from '@/lib/constants';
import { SERVICE_IMAGES } from '@/lib/images';

interface Props {
  title: string;
  description: string;
  slug: string;
  lang: 'es' | 'en';
  relatedServices: Array<{ title: string; slug: string }>;
}

const { title, description, slug, lang, relatedServices } = Astro.props;
const solutionsBase = prefixBase(lang === 'es' ? '/soluciones' : '/en/solutions');
const solutionsLabel = lang === 'es' ? 'Soluciones en Movimiento' : 'Solutions in Motion';
const backLabel = lang === 'es' ? '← Todas las soluciones' : '← All solutions';
const eyebrowLabel = lang === 'es' ? 'Solución' : 'Solution';
const exploreLabel = lang === 'es' ? 'Explorar' : 'Explore';
const heroImage = SERVICE_IMAGES[slug];
---

<PageLayout title={`${title} — LUMISIS`} description={description}>
  {/* Hero */}
  <section class="hero-inner">
    {heroImage && (
      <Image
        src={heroImage}
        alt=""
        width={1920}
        quality={82}
        class="hero-inner__bg"
      />
    )}
    <div class="hero-inner__overlay"></div>
    <Container>
      <div class="hero-inner__content">
        <a href={solutionsBase} class="hero-inner__back" data-reveal>{backLabel}</a>
        <h1 class="hero-inner__title" data-reveal data-reveal-delay="120">{title}</h1>
      </div>
    </Container>
  </section>

  {/* Editorial body */}
  <Section>
    <Container narrow>
      <p class="eyebrow" data-reveal>{eyebrowLabel}</p>
      <p class="service-standfirst" data-reveal data-reveal-delay="80">{description}</p>
      <hr class="service-rule" data-reveal data-reveal-delay="140" />
      <article class="service-article" data-reveal data-reveal-delay="200">
        <slot />
      </article>
    </Container>
  </Section>

  {/* Related Services */}
  {relatedServices.length > 0 && (
    <Section class="whyus-rule">
      <Container>
        <p class="eyebrow mb-8" data-reveal>{solutionsLabel}</p>
        <div class="grid gap-6 sm:grid-cols-2">
          {relatedServices.map((related, i) => (
            <a
              href={`${solutionsBase}/${related.slug}`}
              class="service-related__card"
              data-reveal
              data-reveal-delay={`${i * 80}`}
            >
              <h3 class="service-related__title">{related.title}</h3>
              <span class="service-related__cta">
                <span>{exploreLabel}</span>
                <span class="service-related__cta-arrow">&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </Container>
    </Section>
  )}
</PageLayout>
